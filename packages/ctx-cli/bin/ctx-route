SEMVER_RE = re.compile(r"^\s*(\d+)\.(\d+)\.(\d+)(?:[-+][0-9A-Za-z.-]+)?\s*$")


def default_actor() -> str:
    actor = str(os.environ.get("CTX_ACTOR") or "").strip()
    return actor or "unknown"


def default_site() -> str:
    site = str(os.environ.get("CTX_SITE") or "").strip()
    return site or "local"


def now() -> str:
    return dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def utc_now() -> dt.datetime:
    return dt.datetime.now(dt.timezone.utc).replace(microsecond=0)


def parse_time(value: object) -> dt.datetime | None:
    if not isinstance(value, str) or not value:
        return None
    try:
        parsed = dt.datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        return None
    if parsed.tzinfo is None:
        parsed = parsed.replace(tzinfo=dt.timezone.utc)
    return parsed.astimezone(dt.timezone.utc)


def age_seconds(value: object, reference: dt.datetime | None = None) -> int | None:
    parsed = parse_time(value)
    if not parsed:
        return None
    reference = reference or utc_now()
    return int((reference - parsed).total_seconds())


def transport_probe_arg(value: str) -> dict:
    try:
        name, target = value.split("=", 1)
        host, port_text = target.rsplit(":", 1)
        port = int(port_text)
    except ValueError as exc:
        raise argparse.ArgumentTypeError("expected name=host:port") from exc
    if not name or not host or port < 1 or port > 65535:
        raise argparse.ArgumentTypeError("expected name=host:port with tcp port 1..65535")
    return {"name": name, "host": host, "port": port}


def stamp() -> str:
    return dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def ensure_dirs() -> None:
    for path in [*set(STATUS_DIRS.values()), DEVICES, AGENT_INSTANCES, AGENT_PROFILES, METRICS, ROUTE_CALL_METRICS, LINKS, SHARED]:
        path.mkdir(parents=True, exist_ok=True)


def _acquire_lock(lock) -> None:
    if fcntl is not None:
        fcntl.flock(lock.fileno(), fcntl.LOCK_EX)
    elif msvcrt is not None:  # pragma: no cover - Windows
        lock.seek(0)
        while True:
            try:
                msvcrt.locking(lock.fileno(), msvcrt.LK_LOCK, 1)
                return
            except OSError:
                time.sleep(0.1)


def _release_lock(lock) -> None:
    if fcntl is not None:
        fcntl.flock(lock.fileno(), fcntl.LOCK_UN)
    elif msvcrt is not None:  # pragma: no cover - Windows
        lock.seek(0)
        try:
            msvcrt.locking(lock.fileno(), msvcrt.LK_UNLCK, 1)
        except OSError:
            pass


@contextlib.contextmanager
def locked() -> Iterator[None]:
    ensure_dirs()
    with LOCK.open("a+", encoding="utf-8") as lock:
        _acquire_lock(lock)
        try:
            yield
        finally:
            _release_lock(lock)


def make_route_id() -> str:
    return f"route_{stamp()}_{random.randint(0, 9999):04d}"


def reject_secret_shaped_values(data: object, label: str) -> None:
    text = json.dumps(data, ensure_ascii=False, sort_keys=True)
    if SECRET_VALUE_RE.search(text):
        raise SystemExit(f"{label} contains secret-shaped content; refusing to write")


def safe_text(value: object, limit: int = TASK_SUMMARY_LIMIT) -> object:
    if not isinstance(value, str):
        return value
    if SECRET_VALUE_RE.search(value):
        return "[redacted-secret-shaped]"
    if len(value) > limit:
        return value[:limit] + "...[truncated]"
    return value


def atomic_write(path: Path, data: dict) -> None:
    reject_secret_shaped_values(data, str(path))
    if "route_id" in data:
        normalize_route(data)
        validate_route_schema(data)
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + f".tmp.{os.getpid()}")
    tmp.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    os.replace(tmp, path)


def route_paths(rid: str) -> list[Path]:
    out = []
    for directory in set(STATUS_DIRS.values()):
        path = directory / f"{rid}.json"
        if path.exists():
            out.append(path)
    return out


def route_path(rid: str) -> Path | None:
    matches = route_paths(rid)
    if len(matches) > 1:
        raise SystemExit(f"route has duplicate records: {rid}")
    return matches[0] if matches else None


def load_route(rid: str) -> tuple[Path, dict]:
    path = route_path(rid)
    if not path:
        raise SystemExit(f"route not found: {rid}")
    return path, json.loads(path.read_text(encoding="utf-8"))


def normalize_route(route: dict) -> dict:
    route.setdefault("trace_id", route.get("route_id"))
    if not route.get("lane_id"):
        route["lane_id"] = (
            route.get("work_chat_id")
            or route.get("context_id")
            or route.get("trace_id")
            or route.get("route_id")
        )
    route.setdefault("required_capabilities", [])
    route.setdefault("constraints", [])
    route.setdefault("secret_capabilities", [])
    route.setdefault("artifacts_expected", ["summary", "evidence"])
    route.setdefault("events", [])
    route.setdefault("transparency", {
        "human_readable": True,
        "trace_required": True,
        "evidence_required": True,
        "secret_values_allowed": False,
    })
    return route


def require_string(data: dict, key: str, label: str) -> None:
    if not isinstance(data.get(key), str) or not data.get(key):
        raise SystemExit(f"{label} missing required string field: {key}")


def require_list(data: dict, key: str, label: str) -> None:
    if not isinstance(data.get(key), list):
        raise SystemExit(f"{label} missing required list field: {key}")


def validate_events(route: dict) -> None:
    for index, event in enumerate(route.get("events") or []):
        if not isinstance(event, dict):
            raise SystemExit(f"route event {index} must be object")
        for key in ("ts", "type"):
            if not isinstance(event.get(key), str) or not event.get(key):
                raise SystemExit(f"route event {index} missing {key}")


def validate_route_schema(route: dict) -> None:
    for key in ROUTE_REQUIRED_STRINGS:
        require_string(route, key, "route")
    for key in ROUTE_REQUIRED_LISTS:
        require_list(route, key, "route")
    if route.get("status") not in STATUS_DIRS:
        raise SystemExit(f"route has unsupported status: {route.get('status')}")
    if not isinstance(route.get("approval_required"), bool):
        raise SystemExit("route missing required bool field: approval_required")
    if route.get("reply_to") is not None and not isinstance(route.get("reply_to"), str):
        raise SystemExit("route reply_to must be string or null")
    transparency = route.get("transparency")
    if not isinstance(transparency, dict):
        raise SystemExit("route missing transparency object")
    for key in ("human_readable", "trace_required", "evidence_required", "secret_values_allowed"):
        if not isinstance(transparency.get(key), bool):
            raise SystemExit(f"route transparency missing bool field: {key}")
    validate_events(route)
    if route.get("reply") is not None:
        validate_reply_schema(route["reply"], route.get("route_id"))


def validate_reply_schema(reply: dict, route_id: str | None = None) -> None:
    if not isinstance(reply, dict):
        raise SystemExit("reply must be object")
    for key in REPLY_REQUIRED_STRINGS:
        require_string(reply, key, "reply")
    for key in REPLY_REQUIRED_LISTS:
        require_list(reply, key, "reply")
    if route_id and reply.get("route_id") != route_id:
        raise SystemExit("reply route_id mismatch")
    if reply.get("status") not in ("replied", "blocked", "needs_approval", "failed"):
        raise SystemExit(f"unsupported reply status: {reply.get('status')}")
    for index, evidence in enumerate(reply.get("evidence") or []):
        if not isinstance(evidence, dict):
            raise SystemExit(f"reply evidence {index} must be object")
        require_string(evidence, "kind", f"reply evidence {index}")
    for index, artifact in enumerate(reply.get("artifacts") or []):
        if not isinstance(artifact, dict):
            raise SystemExit(f"reply artifact {index} must be object")
        require_string(artifact, "kind", f"reply artifact {index}")
        require_string(artifact, "path", f"reply artifact {index}")


def inherited_route_scope(reply_to: str | None) -> dict | None:
    if not reply_to:
        return None
    path = route_path(reply_to)
    if not path:
        return None
    return json.loads(path.read_text(encoding="utf-8"))


def route_lane_id(route: dict) -> object:
    return (
        route.get("lane_id")
        or route.get("work_chat_id")
        or route.get("context_id")
        or route.get("trace_id")
        or route.get("route_id")
    )


def inherited_trace_id(reply_to: str | None) -> str | None:
    parent = inherited_route_scope(reply_to)
    if not parent:
        return None
    return parent.get("trace_id") or parent.get("route_id")


def resolve_trace_id(reply_to: str | None, explicit_trace_id: str | None, route_id: str) -> str:
    parent_trace_id = inherited_trace_id(reply_to)
    if explicit_trace_id and parent_trace_id and explicit_trace_id != parent_trace_id:
        raise SystemExit(
            f"trace_id conflict: reply_to {reply_to} belongs to {parent_trace_id}, "
            f"but explicit trace_id is {explicit_trace_id}"
        )
    return explicit_trace_id or parent_trace_id or route_id


def resolve_lane_scope(
    *,
    reply_to: str | None,
    trace_id: str,
    route_id: str,
    lane_id: str | None,
    work_chat_id: str | None,
    context_id: str | None,
) -> dict:
    parent = inherited_route_scope(reply_to)
    if parent:
        parent_lane_id = route_lane_id(parent)
        if lane_id and parent_lane_id and lane_id != parent_lane_id:
            raise SystemExit(
                f"lane_id conflict: reply_to {reply_to} belongs to {parent_lane_id}, "
                f"but explicit lane_id is {lane_id}"
            )
        parent_work_chat_id = parent.get("work_chat_id")
        if work_chat_id and parent_work_chat_id and work_chat_id != parent_work_chat_id:
            raise SystemExit(
                f"work_chat_id conflict: reply_to {reply_to} belongs to {parent_work_chat_id}, "
                f"but explicit work_chat_id is {work_chat_id}"
            )
        parent_context_id = parent.get("context_id")
        if context_id and parent_context_id and context_id != parent_context_id:
            raise SystemExit(
                f"context_id conflict: reply_to {reply_to} belongs to {parent_context_id}, "
                f"but explicit context_id is {context_id}"
            )
        return {
            "lane_id": lane_id or parent_lane_id or trace_id or route_id,
            "work_chat_id": work_chat_id or parent_work_chat_id,
            "context_id": context_id or parent_context_id,
        }
    return {
        "lane_id": lane_id or work_chat_id or context_id or trace_id or route_id,
        "work_chat_id": work_chat_id,
        "context_id": context_id,
    }


def move_route(old_path: Path, route: dict, status: str) -> Path:
    new_dir = STATUS_DIRS.get(status)
    if not new_dir:
        raise SystemExit(f"unsupported route status: {status}")
    route["status"] = status
    route["updated_at"] = now()
    new_path = new_dir / old_path.name
    atomic_write(new_path, route)
    if old_path != new_path and old_path.exists():
        old_path.unlink()
    return new_path


def lease_expired(route: dict, reference: dt.datetime | None = None) -> bool:
    lease = route.get("lease") if isinstance(route.get("lease"), dict) else {}
    expires_at = parse_time(lease.get("expires_at"))
    return bool(expires_at and expires_at < (reference or utc_now()))


def make_lease_id() -> str:
    return "lease_" + uuid.uuid4().hex[:16]


def require_current_lease(
    route: dict,
    *,
    agent_id: str | None,
    instance_id: str | None,
    lease_id: str | None,
    action: str,
) -> None:
    lease = route.get("lease") if isinstance(route.get("lease"), dict) else {}
    if not lease:
        raise SystemExit(f"route cannot {action}: active lease is missing")
    current_lease_id = lease.get("lease_id")
    provided_lease_id = lease_id if lease_id not in (None, "") else None
    if current_lease_id and provided_lease_id is not None and provided_lease_id != current_lease_id:
        raise SystemExit(f"route cannot {action}: lease_id mismatch")
    claimed_by = lease.get("claimed_by")
    if claimed_by and agent_id != claimed_by:
        raise SystemExit(f"route cannot {action}: agent_id does not own the lease")
    claim_instance_id = lease.get("claim_instance_id")
    if claim_instance_id and instance_id != claim_instance_id:
        raise SystemExit(f"route cannot {action}: instance_id does not own the lease")
    if lease_expired(route):
        raise SystemExit(f"route cannot {action}: active lease has expired")


def active_route_records(reference: dt.datetime | None = None) -> list[tuple[Path, dict]]:
    reference = reference or utc_now()
    return [
        (path, route)
        for path, route in iter_routes()
        if route.get("status") in ACTIVE_STATUSES and not lease_expired(route, reference)
    ]


def route_capacity_key(route: dict) -> tuple[object, object]:
    return (route.get("target_site"), route.get("target_agent"))


def lane_capacity_key(route: dict) -> object:
    return route_lane_id(route)


def pending_route_records() -> list[tuple[Path, dict]]:
    return [
        (path, route)
        for path, route in iter_routes()
        if route.get("status") in {"planned", "queued"}
    ]


def read_json_arg(value: str) -> dict:
    if value == "-":
        return json.load(sys.stdin)
    return json.loads(Path(value).read_text(encoding="utf-8"))


def sanitize_agent_key(agent_key: str) -> str:
    return re.sub(r"[^A-Za-z0-9._-]", "_", str(agent_key or ""))


def agent_profile_path(agent_key: str) -> Path:
    safe_key = sanitize_agent_key(agent_key).strip("._") or "unknown"
    return AGENT_PROFILES / f"{safe_key}.json"


def default_audit_profile() -> dict:
    return {
        "result_link_kind": "strict",
        "expects_thread_id": False,
        "ephemeral_session": False,
        "thread_field": "thread",
        "thread_id_field": "id",
        "thread_model_field": "model",
        "thread_id_output_field": "thread_id",
        "thread_model_output_field": "thread_model",
    }


def normalize_agent_profile(profile: dict) -> dict:
    normalized = json.loads(json.dumps(profile, ensure_ascii=False))
    normalized.setdefault("schema", AGENT_PROFILE_SCHEMA)
    normalized.setdefault("constraints_supported", [])
    normalized.setdefault("transports", [])
    normalized.setdefault("availability", "unknown")
    normalized.setdefault("audit_profile", default_audit_profile())
    normalized.setdefault("secret_capabilities", [])
    normalized.setdefault("red_lines", [])
    audit_profile = normalized.get("audit_profile")
    if not isinstance(audit_profile, dict):
        audit_profile = {}
    merged_audit = default_audit_profile()
    merged_audit.update(audit_profile)
    normalized["audit_profile"] = merged_audit
    for key in AGENT_PROFILE_LIST_FIELDS:
        value = normalized.get(key)
        if value is None:
            normalized[key] = []
    return normalized


def validate_agent_profile(profile: dict) -> list[str]:
    errors: list[str] = []
    if profile.get("schema") != AGENT_PROFILE_SCHEMA:
        errors.append(f"schema must be {AGENT_PROFILE_SCHEMA}")
    for field in AGENT_PROFILE_REQUIRED_FIELDS:
        if not profile.get(field):
            errors.append(f"missing required field: {field}")
    if profile.get("kind") and profile.get("kind") not in AGENT_PROFILE_VALID_KINDS:
        errors.append(f"kind must be one of {sorted(AGENT_PROFILE_VALID_KINDS)}")
    engine = profile.get("engine")
    if engine is not None and not isinstance(engine, dict):
        errors.append("engine must be an object")
    audit_profile = profile.get("audit_profile")
    if audit_profile is not None and not isinstance(audit_profile, dict):
        errors.append("audit_profile must be an object")
    for field in AGENT_PROFILE_LIST_FIELDS:
        value = profile.get(field)
        if value is not None and not isinstance(value, list):
            errors.append(f"{field} must be a list")
    return errors


def load_agent_profile(agent_key: str) -> dict | None:
    path = agent_profile_path(agent_key)
    if not path.exists():
        return None
    try:
        profile = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return None
    if isinstance(profile, dict):
        profile["_path"] = str(path)
        return profile
    return None


@functools.lru_cache(maxsize=1)
def agent_profiles_by_agent_id() -> dict[str, list[dict]]:
    rows: dict[str, list[dict]] = {}
    for profile in list_agent_profiles():
        if not isinstance(profile, dict):
            continue
        seen_agent_ids: set[str] = set()
        for agent_id in (profile.get("agent_id"), profile.get("previous_agent_id")):
            text = str(agent_id or "").strip()
            if not text or text in seen_agent_ids:
                continue
            seen_agent_ids.add(text)
            rows.setdefault(text, []).append(profile)
    return rows


def clear_agent_profile_cache() -> None:
    agent_profiles_by_agent_id.cache_clear()


def list_agent_profiles() -> list[dict]:
    ensure_dirs()
    rows = []
    for path in sorted(AGENT_PROFILES.glob("*.json")):
        if path.name == AGENT_PROFILE_HISTORY.name:
            continue
        try:
            profile = json.loads(path.read_text(encoding="utf-8"))
        except Exception as exc:
            rows.append({"agent_key": path.stem, "_path": str(path), "error": str(exc)})
            continue
        if isinstance(profile, dict):
            profile["_path"] = str(path)
            rows.append(profile)
    return rows


def agent_profile_transport_source(profile: dict) -> str | None:
    transports = profile.get("transports")
    if isinstance(transports, list) and transports:
        first = transports[0]
        return canonical_transport_source(first)
    return None


def canonical_transport_source(value: object) -> str | None:
    if value is None:
        return None
    text = str(value).strip()
    if not text:
        return None
    if text == "local":
        return "transport.local"
    return text


def register_agent_profile(profile: dict) -> dict:
    normalized = normalize_agent_profile(profile)
    errors = validate_agent_profile(normalized)
    if errors:
        raise SystemExit("profile rejected:\n  - " + "\n  - ".join(errors))
    key = str(normalized["agent_key"])
    prior = load_agent_profile(key)
    prior_payload = dict(prior) if prior else None
    if prior_payload:
        prior_payload.pop("_path", None)
    transport_source = agent_profile_transport_source(normalized)
    rebind_flag = None
    if prior_payload is None:
        normalized["key_owner"] = {
            "device_id": normalized["device_id"],
            "transport": transport_source,
            "pinned_at": now(),
        }
    else:
        owner = prior_payload.get("key_owner") if isinstance(prior_payload.get("key_owner"), dict) else {}
        if not owner:
            owner = {
                "device_id": prior_payload.get("device_id") or normalized["device_id"],
                "transport": agent_profile_transport_source(prior_payload),
                "pinned_at": prior_payload.get("registered_at") or now(),
            }
        owner["transport"] = canonical_transport_source(owner.get("transport"))
        normalized["key_owner"] = owner
        mismatch_parts = []
        if owner.get("device_id") and owner.get("device_id") != normalized["device_id"]:
            mismatch_parts.append(f"device_id pinned={owner.get('device_id')} got={normalized['device_id']}")
        owner_transport = owner.get("transport")
        if owner_transport and transport_source and owner_transport != transport_source:
            mismatch_parts.append(f"transport pinned={owner_transport} got={transport_source}")
        if mismatch_parts:
            rebind_flag = (
                f"agent_key '{key}' changed pinned origin; "
                + "; ".join(mismatch_parts)
                + " (flagged; enforcement deferred to Secret Box)"
            )
        normalized["previous_agent_id"] = prior_payload.get("agent_id")
    normalized["registered_at"] = now()
    path = agent_profile_path(key)
    atomic_write(path, normalized)
    clear_agent_profile_cache()
    history_entry = {
        "at": now(),
        "agent_key": key,
        "agent_id": normalized["agent_id"],
        "device_id": normalized["device_id"],
        "capabilities": normalized.get("capabilities") or [],
        "rebind_flag": rebind_flag,
    }
    reject_secret_shaped_values(history_entry, str(AGENT_PROFILE_HISTORY))
    with AGENT_PROFILE_HISTORY.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(history_entry, ensure_ascii=False) + "\n")
    out = {"registered": key, "agent_id": normalized["agent_id"], "path": str(path)}
    previous_agent_id = normalized.get("previous_agent_id")
    if previous_agent_id and previous_agent_id != normalized["agent_id"]:
        out["rebound_from"] = previous_agent_id
    if rebind_flag:
        out["WARN"] = rebind_flag
    return out


def read_json_text(value: str, label: str) -> dict:
    try:
        data = json.loads(value)
    except json.JSONDecodeError as exc:
        raise SystemExit(f"{label} must be valid JSON") from exc
    if not isinstance(data, dict):
        raise SystemExit(f"{label} must be a JSON object")
    return data


def parse_bool_text(value: str, label: str) -> bool:
    text = str(value).strip().lower()
    if text in {"1", "true", "yes", "on"}:
        return True
    if text in {"0", "false", "no", "off"}:
        return False
    raise SystemExit(f"{label} must be true or false")


def load_policy() -> dict:
    ensure_dirs()
    if not POLICY.exists():
        return {}
    try:
        data = json.loads(POLICY.read_text(encoding="utf-8"))
    except Exception as exc:
        raise SystemExit(f"policy could not be read: {exc}") from exc
    if not isinstance(data, dict):
        raise SystemExit("policy must be a JSON object")
    return data


def policy_bool(key: str, env_name: str, default: bool = False) -> bool:
    if env_name in os.environ:
        return parse_bool_text(os.environ[env_name], env_name)
    value = load_policy().get(key)
    if isinstance(value, bool):
        return value
    return default


def parse_non_negative_int(value: object, label: str) -> int:
    try:
        number = int(value)
    except (TypeError, ValueError) as exc:
        raise SystemExit(f"{label} must be a non-negative integer") from exc
    if number < 0:
        raise SystemExit(f"{label} must be a non-negative integer")
    return number


def policy_int(key: str, env_name: str, default: int) -> int:
    if env_name in os.environ:
        return parse_non_negative_int(os.environ[env_name], env_name)
    value = load_policy().get(key)
    if value is None:
        return default
    return parse_non_negative_int(value, key)


