def default_circuit_breaker_state() -> dict:
    return {
        "schema": CIRCUIT_BREAKER_SCHEMA,
        "state": "closed",
        "severity": None,
        "reason": "",
        "opened_at": None,
        "opened_by": None,
        "closed_at": None,
        "closed_by": None,
        "updated_at": None,
        "updated_by": None,
        "last_evaluated_at": None,
        "last_trip": None,
    }


def normalize_circuit_breaker_state(data: dict | None) -> dict:
    state = default_circuit_breaker_state()
    if isinstance(data, dict):
        state.update(data)
    if state.get("schema") != CIRCUIT_BREAKER_SCHEMA:
        state["schema"] = CIRCUIT_BREAKER_SCHEMA
    if state.get("state") not in CIRCUIT_BREAKER_STATES:
        state["state"] = "closed"
    if state.get("severity") not in CIRCUIT_BREAKER_SEVERITIES:
        state["severity"] = None
    return state


def load_circuit_breaker() -> dict:
    ensure_dirs()
    if not CIRCUIT_BREAKER.exists():
        return default_circuit_breaker_state()
    try:
        data = json.loads(CIRCUIT_BREAKER.read_text(encoding="utf-8"))
    except Exception as exc:
        raise SystemExit(f"circuit breaker state could not be read: {exc}") from exc
    if not isinstance(data, dict):
        raise SystemExit("circuit breaker state must be a JSON object")
    return normalize_circuit_breaker_state(data)


def write_circuit_breaker(state: dict) -> dict:
    normalized = normalize_circuit_breaker_state(state)
    atomic_write(CIRCUIT_BREAKER, normalized)
    return normalized


def circuit_breaker_public_state() -> dict:
    state = load_circuit_breaker()
    state["enabled"] = circuit_breaker_enabled()
    return state


def circuit_breaker_policy_snapshot() -> dict:
    return {
        "enabled": circuit_breaker_enabled(),
        "open_on_doctor_critical": circuit_breaker_open_on_doctor_critical(),
        "open_on_doctor_warn": circuit_breaker_open_on_doctor_warn(),
        "max_active_routes": circuit_breaker_max_active_routes(),
        "max_pending_routes": circuit_breaker_max_pending_routes(),
    }


def circuit_breaker_pressure_trip(action: str, reference: dt.datetime | None = None) -> dict | None:
    reference = reference or utc_now()
    active = active_route_records(reference)
    pending = pending_route_records()
    active_limit = circuit_breaker_max_active_routes()
    pending_limit = circuit_breaker_max_pending_routes()
    trip_reasons = []
    if active_limit > 0 and len(active) >= active_limit:
        trip_reasons.append(
            f"active_routes={len(active)} reached circuit_breaker_max_active_routes={active_limit}"
        )
    if action == "create" and pending_limit > 0 and len(pending) >= pending_limit:
        trip_reasons.append(
            f"pending_routes={len(pending)} reached circuit_breaker_max_pending_routes={pending_limit}"
        )
    if not trip_reasons:
        return None
    severity = "critical" if active_limit > 0 and len(active) >= active_limit else "warn"
    return {
        "kind": "route_pressure_threshold",
        "action": action,
        "severity": severity,
        "reason": "; ".join(trip_reasons),
        "active_routes": len(active),
        "pending_routes": len(pending),
        "policy": circuit_breaker_policy_snapshot(),
    }


def circuit_breaker_open(reason: str, by: str, severity: str = "critical", trip: dict | None = None) -> dict:
    if severity not in CIRCUIT_BREAKER_SEVERITIES:
        raise SystemExit("--severity must be warn or critical")
    current = load_circuit_breaker()
    opened_at = current.get("opened_at") if current.get("state") == "open" else now()
    state = {
        **current,
        "schema": CIRCUIT_BREAKER_SCHEMA,
        "state": "open",
        "severity": severity,
        "reason": reason,
        "opened_at": opened_at,
        "opened_by": current.get("opened_by") if current.get("state") == "open" else by,
        "closed_at": None,
        "closed_by": None,
        "updated_at": now(),
        "updated_by": by,
        "last_evaluated_at": (trip or {}).get("evaluated_at") or current.get("last_evaluated_at"),
        "last_trip": trip,
    }
    return write_circuit_breaker(state)


def circuit_breaker_close(reason: str, by: str) -> dict:
    current = load_circuit_breaker()
    state = {
        **current,
        "schema": CIRCUIT_BREAKER_SCHEMA,
        "state": "closed",
        "severity": None,
        "reason": reason,
        "closed_at": now(),
        "closed_by": by,
        "updated_at": now(),
        "updated_by": by,
    }
    return write_circuit_breaker(state)


def circuit_breaker_block_message(action: str, state: dict) -> str:
    reason = state.get("reason") or "no reason recorded"
    opened_at = state.get("opened_at") or "unknown"
    opened_by = state.get("opened_by") or "unknown"
    prefix = "route not claimable" if action == "claim" else "route creation blocked"
    return f"{prefix}: circuit breaker open: {reason} opened_at={opened_at} opened_by={opened_by}"


def enforce_circuit_breaker(action: str) -> None:
    if not circuit_breaker_enabled():
        return
    state = load_circuit_breaker()
    if state.get("state") == "open":
        raise SystemExit(circuit_breaker_block_message(action, state))
    trip = circuit_breaker_pressure_trip(action)
    if trip:
        state = circuit_breaker_open(
            trip["reason"],
            by=f"ctx-route:{action}-preflight",
            severity=trip["severity"],
            trip=trip,
        )
        raise SystemExit(circuit_breaker_block_message(action, state))


def parse_csv_arg(values: list[str] | None) -> list[str]:
    out: list[str] = []
    for value in values or []:
        for item in value.split(","):
            item = item.strip()
            if item:
                out.append(item)
    return out


def parse_semver(value: object) -> tuple[int, int, int] | None:
    if not isinstance(value, str):
        return None
    match = SEMVER_RE.match(value)
    if not match:
        return None
    major, minor, patch = match.groups()
    return (int(major), int(minor), int(patch))


def unknown_route_capability_tokens(route: dict) -> list[str]:
    unknown = {
        str(token)
        for field in ("required_capabilities", "secret_capabilities")
        for token in (route.get(field) or [])
        if str(token) not in CAPABILITY_VOCAB
    }
    return sorted(unknown)


def agent_approval_capable(profile: dict) -> bool:
    return bool(profile.get("approval_capable"))


def engine_eligible(route: dict, profile: dict) -> tuple[bool, str | None, dict]:
    matched = {
        "target_site": False,
        "required_capabilities": [],
        "constraints": [],
        "required_engine": None,
        "approval_required": not bool(route.get("approval_required")),
        "secret_capabilities": route.get("secret_capabilities") == [],
    }
    if route.get("status") != "queued":
        return False, f"route status must be queued, got {route.get('status')}", matched
    target_site = str(route.get("target_site") or "")
    device_id = str(profile.get("device_id") or "")
    matched["target_site"] = target_matches(route, device_id)
    if not matched["target_site"]:
        return False, f"target_site mismatch: route={target_site} agent={device_id}", matched
    unknown_tokens = unknown_route_capability_tokens(route)
    if unknown_tokens:
        return False, f"unknown capability token(s): {', '.join(unknown_tokens)}", matched
    capabilities = {str(item) for item in (profile.get("capabilities") or [])}
    required_capabilities = [str(item) for item in (route.get("required_capabilities") or [])]
    missing_capabilities = [token for token in required_capabilities if token not in capabilities]
    if missing_capabilities:
        return False, f"missing required capabilities: {', '.join(missing_capabilities)}", matched
    matched["required_capabilities"] = required_capabilities
    supported_constraints = {str(item) for item in (profile.get("constraints_supported") or [])}
    route_constraints = [str(item) for item in (route.get("constraints") or [])]
    missing_constraints = [token for token in route_constraints if token not in supported_constraints]
    if missing_constraints:
        return False, f"missing supported constraints: {', '.join(missing_constraints)}", matched
    matched["constraints"] = route_constraints
    required_engine = route.get("required_engine")
    if required_engine is not None:
        if not isinstance(required_engine, dict):
            return False, "required_engine must be an object", matched
        engine = profile.get("engine") if isinstance(profile.get("engine"), dict) else {}
        required_name = str(required_engine.get("name") or "").strip()
        version_min = str(required_engine.get("version_min") or "").strip()
        if not required_name or not version_min:
            return False, "required_engine must include name and version_min", matched
        route_version = parse_semver(version_min)
        agent_version = parse_semver(engine.get("version"))
        if route_version is None:
            return False, f"required_engine.version_min is not semver: {version_min}", matched
        if str(engine.get("name") or "").strip() != required_name:
            return False, f"required_engine.name mismatch: need {required_name}", matched
        if agent_version is None:
            return False, f"agent engine.version is not semver: {engine.get('version')}", matched
        if agent_version < route_version:
            return False, f"agent engine.version {engine.get('version')} < required {version_min}", matched
        matched["required_engine"] = {
            "name": required_name,
            "version_min": version_min,
            "agent_version": engine.get("version"),
        }
    if route.get("approval_required") and not agent_approval_capable(profile):
        return False, "approval_required but agent is not approval-capable", matched
    matched["approval_required"] = True
    if route.get("secret_capabilities") != []:
        return False, "secret_capabilities are default-deny before Secret Box", matched
    return True, None, matched


def match_report(route: dict) -> dict:
    report = {
        "route_id": route.get("route_id"),
        "required_capabilities": route.get("required_capabilities") or [],
        "eligible_agents": [],
    }
    if route.get("required_engine") is not None:
        report["required_engine"] = route.get("required_engine")
    unknown_tokens = unknown_route_capability_tokens(route)
    if unknown_tokens:
        report["unroutable_reason"] = f"unknown capability token(s): {', '.join(unknown_tokens)}"
        return report
    for profile in list_agent_profiles():
        if not isinstance(profile, dict) or profile.get("error"):
            continue
        ok, reason, matched = engine_eligible(route, profile)
        if ok:
            report["eligible_agents"].append({
                "agent_key": profile.get("agent_key"),
                "agent_id": profile.get("agent_id"),
                "matched": matched,
            })
        elif reason and reason.startswith("unknown capability token(s):"):
            report["unroutable_reason"] = reason
            report["eligible_agents"] = []
            break
    report["eligible_agents"].sort(key=lambda item: (str(item.get("agent_key") or ""), str(item.get("agent_id") or "")))
    return report


def audit_profile_snapshot_from_agent_profile(profile: dict) -> dict:
    audit_profile = profile.get("audit_profile") if isinstance(profile.get("audit_profile"), dict) else {}
    snapshot = default_audit_profile()
    result_link_kind = str(audit_profile.get("result_link_kind") or snapshot["result_link_kind"]).strip()
    if re.match(r"^[A-Za-z0-9_.:-]+$", result_link_kind):
        snapshot["result_link_kind"] = result_link_kind
    if isinstance(audit_profile.get("expects_thread_id"), bool):
        snapshot["expects_thread_id"] = audit_profile["expects_thread_id"]
    if isinstance(audit_profile.get("ephemeral_session"), bool):
        snapshot["ephemeral_session"] = audit_profile["ephemeral_session"]
    for key in ("thread_field", "thread_id_field", "thread_model_field", "thread_id_output_field", "thread_model_output_field"):
        value = str(audit_profile.get(key) or "").strip()
        if re.match(r"^[A-Za-z0-9_.:-]+$", value):
            snapshot[key] = value
    return snapshot


def capability_for_claim_profile(raw_value: object) -> str:
    value = str(raw_value or "").strip()
    return CAPABILITY_COMPAT_ALIASES.get(value, value)


def claim_profile_match_route(route: dict) -> dict:
    match_route = dict(route)
    match_route["required_capabilities"] = [
        capability_for_claim_profile(item)
        for item in (route.get("required_capabilities") or [])
    ]
    match_route["secret_capabilities"] = [
        capability_for_claim_profile(item)
        for item in (route.get("secret_capabilities") or [])
    ]
    return match_route


def claim_profile_match_profile(profile: dict) -> dict:
    match_profile = dict(profile)
    capabilities = set()
    for token in profile.get("capabilities") or []:
        value = str(token)
        capabilities.add(value)
        capabilities.add(capability_for_claim_profile(value))
    match_profile["capabilities"] = sorted(capabilities)
    return match_profile


def profile_matches_claim_device(profile: dict, device_id: str) -> bool:
    profile_device = str(profile.get("device_id") or "").strip()
    claim_device = str(device_id or "").strip()
    if not profile_device or not claim_device:
        return False
    if profile_device == claim_device:
        return True
    return target_matches({"target_site": profile_device}, claim_device)


def claim_agent_profile_for_route(route: dict, device_id: str, agent_id: str) -> dict | None:
    matches = agent_profiles_by_agent_id().get(str(agent_id or "").strip()) or []
    match_route = claim_profile_match_route(route)
    candidates = []
    for profile in matches:
        if not isinstance(profile, dict) or profile.get("error"):
            continue
        if not profile_matches_claim_device(profile, device_id):
            continue
        ok, _reason, _matched = engine_eligible(match_route, claim_profile_match_profile(profile))
        if ok:
            candidates.append(profile)
    return candidates[0] if len(candidates) == 1 else None


def claim_agent_profile_lease_fields(route: dict, device_id: str, agent_id: str, claimed_at: str) -> dict:
    profile = claim_agent_profile_for_route(route, device_id, agent_id)
    if not profile:
        return {}
    fields = {
        "agent_key": str(profile.get("agent_key") or ""),
        "agent_profile_agent_id": str(profile.get("agent_id") or ""),
        "agent_profile_schema": str(profile.get("schema") or ""),
        "agent_profile_registered_at": profile.get("registered_at"),
        "audit_profile_snapshot": audit_profile_snapshot_from_agent_profile(profile),
        "audit_profile_snapshot_at": claimed_at,
    }
    return {key: value for key, value in fields.items() if value not in (None, "")}


def safe_record_id(value: object) -> str:
    text = str(value or "unknown")
    return re.sub(r"[^A-Za-z0-9_.:-]+", "_", text).strip("._") or "unknown"


def iter_routes() -> list[tuple[Path, dict]]:
    ensure_dirs()
    items: list[tuple[Path, dict]] = []
    for directory in set(STATUS_DIRS.values()):
        for path in directory.glob("*.json"):
            try:
                items.append((path, json.loads(path.read_text(encoding="utf-8"))))
            except Exception as exc:
                items.append((path, {"route_id": path.stem, "status": "parse_error", "error": str(exc)}))
    return sorted(items, key=lambda item: item[0].stat().st_mtime)


def reconcile_audit_id() -> str:
    return f"reconcile_{stamp()}_{os.getpid()}_{random.randint(0, 9999):04d}"


def write_reconcile_audit_record(
    *,
    audit_run_id: str,
    action: dict,
    path: Path,
    route: dict,
    by: str,
) -> str:
    rid = action.get("route_id") or route.get("route_id") or path.stem
    action_name = action.get("action") or "action"
    out = RECONCILE_AUDIT / safe_record_id(audit_run_id) / f"{safe_record_id(rid)}__{safe_record_id(action_name)}.before.json"
    record = {
        "schema": "ctx-reconcile-audit-v1",
        "audit_run_id": audit_run_id,
        "generated_at": now(),
        "by": by,
        "route_path": str(path),
        "action": action,
        "route_before": json.loads(json.dumps(route, ensure_ascii=False)),
    }
    atomic_write(out, record)
    return str(out)


def reconcile_routes(
    *,
    max_retries: int = DEFAULT_RECONCILE_MAX_RETRIES,
    dry_run: bool = False,
    by: str = "ctx-route:reconcile",
    reference: dt.datetime | None = None,
    queued_warn_seconds: int = 1800,
    unverified_warn_seconds: int = 1800,
    terminal_verdict: str = "observe",
    invalid_verified_verdict: str = "observe",
    stale_queued_action: str = "observe",
    audit_run_id: str | None = None,
) -> dict:
    reference = reference or utc_now()
    audit_run_id = audit_run_id or reconcile_audit_id()
    actions = []
    observations = []
    for path, route in iter_routes():
        rid = route.get("route_id") or path.stem
        status = route.get("status")
        if status in ACTIVE_STATUSES and lease_expired(route, reference):
            retries = int(route.get("retry_count") or 0)
            claimed_by = (route.get("lease") or {}).get("claimed_by")
            if retries >= max_retries:
                action = "expire"
                reason = f"lease expired and retry_count={retries} >= max={max_retries}; executor presumed dead"
            else:
                action = "requeue"
                reason = f"lease expired on executor {claimed_by or '?'}; reconcile auto-reclaim for re-dispatch"
            action_record = {
                "route_id": rid,
                "action": action,
                "from_status": status,
                "retry_count": retries,
                "claimed_by": claimed_by,
                "reason": reason,
                "dry_run": dry_run,
            }
            actions.append(action_record)
            if not dry_run:
                action_record["audit_path"] = write_reconcile_audit_record(
                    audit_run_id=audit_run_id,
                    action=action_record,
                    path=path,
                    route=route,
                    by=by,
                )
                if action == "expire":
                    append_event(route, "route_expired", by=by, reason=reason)
                    move_route(path, route, "expired")
                else:
                    route["lease"] = None
                    route["retry_count"] = retries + 1
                    append_event(route, "route_requeued", by=by, reason=reason, retry_count=route["retry_count"])
                    move_route(path, route, "queued")
        elif status == "queued":
            created_age = age_seconds(route.get("created_at"), reference)
            if created_age is not None and created_age > queued_warn_seconds:
                if stale_queued_action == "observe":
                    observations.append({
                        "route_id": rid,
                        "kind": "stale_queued_route",
                        "status": status,
                        "age_seconds": created_age,
                        "action": "observe",
                    })
                elif stale_queued_action == "expire":
                    reason = f"queued route remained unclaimed for {created_age}s; reconcile expires it"
                    action_record = {
                        "route_id": rid,
                        "action": "expire_stale_queued",
                        "kind": "stale_queued_route",
                        "from_status": status,
                        "to_status": "expired",
                        "age_seconds": created_age,
                        "reason": reason,
                        "dry_run": dry_run,
                    }
                    actions.append(action_record)
                    if not dry_run:
                        action_record["audit_path"] = write_reconcile_audit_record(
                            audit_run_id=audit_run_id,
                            action=action_record,
                            path=path,
                            route=route,
                            by=by,
                        )
                        append_event(route, "route_expired", by=by, reason=reason)
                        move_route(path, route, "expired")
                else:
                    raise SystemExit(f"unsupported stale queued action: {stale_queued_action}")
        elif status in UNVERIFIED_TERMINAL_STATUSES and not route.get("verification"):
            updated_age = age_seconds(route.get("updated_at"), reference)
            if updated_age is None or updated_age > unverified_warn_seconds:
                if terminal_verdict == "observe":
                    observations.append({
                        "route_id": rid,
                        "kind": "unverified_terminal_route",
                        "status": status,
                        "age_seconds": updated_age,
                        "action": "observe",
                    })
                else:
                    reason = (
                        f"terminal route remained unverified for {updated_age}s; "
                        f"reconcile closes it as {terminal_verdict}"
                    )
                    target_status = verification_status_for_verdict(terminal_verdict)
                    action_record = {
                        "route_id": rid,
                        "action": "verify_terminal",
                        "kind": "unverified_terminal_route",
                        "from_status": status,
                        "to_status": target_status,
                        "verdict": terminal_verdict,
                        "age_seconds": updated_age,
                        "reason": reason,
                        "dry_run": dry_run,
                    }
                    actions.append(action_record)
                    if not dry_run:
                        action_record["audit_path"] = write_reconcile_audit_record(
                            audit_run_id=audit_run_id,
                            action=action_record,
                            path=path,
                            route=route,
                            by=by,
                        )
                        apply_verification(path, route, by, terminal_verdict, reason)
        elif verified_without_successful_reply(route):
            if invalid_verified_verdict == "observe":
                observations.append({
                    "route_id": rid,
                    "kind": "verified_without_successful_reply",
                    "status": status,
                    "action": "observe",
                })
            else:
                reason = (
                    "route was previously marked verified but does not have "
                    "accepted verification over a successful reply; reconcile reclassifies it"
                )
                target_status = verification_status_for_verdict(invalid_verified_verdict)
                action_record = {
                    "route_id": rid,
                    "action": "reclassify_invalid_verified",
                    "kind": "verified_without_successful_reply",
                    "from_status": status,
                    "to_status": target_status,
                    "verdict": invalid_verified_verdict,
                    "reason": reason,
                    "dry_run": dry_run,
                }
                actions.append(action_record)
                if not dry_run:
                    action_record["audit_path"] = write_reconcile_audit_record(
                        audit_run_id=audit_run_id,
                        action=action_record,
                        path=path,
                        route=route,
                        by=by,
                    )
                    apply_verification_correction(path, route, by, invalid_verified_verdict, reason)
    return {
        "generated_at": now(),
        "dry_run": dry_run,
        "audit_run_id": audit_run_id,
        "max_retries": max_retries,
        "action_count": len(actions),
        "observation_count": len(observations),
        "actions": actions,
        "observations": observations,
    }


def enforce_claim_capacity(route: dict, reference: dt.datetime | None = None) -> None:
    reference = reference or utc_now()
    active = [item for _path, item in active_route_records(reference)]
    total_limit = max_active_routes_total()
    if total_limit > 0 and len(active) >= total_limit:
        raise SystemExit(
            f"route not claimable: route capacity exceeded: active_routes={len(active)} "
            f"max_active_routes_total={total_limit}"
        )
    target_limit = max_active_routes_per_target()
    if target_limit > 0:
        target = route_capacity_key(route)
        active_for_target = [item for item in active if route_capacity_key(item) == target]
        if len(active_for_target) >= target_limit:
            raise SystemExit(
                "route not claimable: route capacity exceeded: "
                f"active_routes_for_target={len(active_for_target)} "
                f"target_site={target[0]} target_agent={target[1]} "
                f"max_active_routes_per_target={target_limit}"
            )
    lane_limit = max_active_routes_per_lane()
    if lane_limit > 0:
        lane = lane_capacity_key(route)
        active_for_lane = [item for item in active if lane_capacity_key(item) == lane]
        if len(active_for_lane) >= lane_limit:
            raise SystemExit(
                "route not claimable: route capacity exceeded: "
                f"active_routes_for_lane={len(active_for_lane)} "
                f"lane_id={lane} "
                f"max_active_routes_per_lane={lane_limit}"
            )


def load_agent_instance_record(device_id: str, agent_id: str, instance_id: str | None) -> dict | None:
    if not instance_id:
        return None
    path = agent_instance_path(device_id, agent_id, instance_id)
    if not path.exists():
        return None
    try:
        record = json.loads(path.read_text(encoding="utf-8"))
    except Exception as exc:
        raise SystemExit(f"route not claimable: agent instance heartbeat could not be read: {exc}") from exc
    if not isinstance(record, dict):
        raise SystemExit("route not claimable: agent instance heartbeat must be an object")
    return record


def enforce_claim_agent_code_current(*, device_id: str, agent_id: str, instance_id: str | None) -> None:
    if not claim_agent_code_current_required() or not instance_id:
        return
    instance = load_agent_instance_record(device_id, agent_id, instance_id)
    if not instance:
        return
    agent_code = instance.get("agent_code") if isinstance(instance.get("agent_code"), dict) else {}
    sha256 = agent_code.get("sha256")
    loaded_sha256 = agent_code.get("loaded_sha256")
    if sha256 and loaded_sha256 and sha256 != loaded_sha256:
        raise SystemExit(
            "route not claimable: agent loaded code differs from current tool file; restart claimant before claiming"
        )
    started_at = parse_time(instance.get("started_at"))
    tool_mtime = parse_time(agent_code.get("mtime"))
    if started_at and tool_mtime and tool_mtime > started_at:
        raise SystemExit(
            "route not claimable: agent process predates current tool file; restart claimant before claiming"
        )


def enforce_pending_capacity(route: dict) -> None:
    target_limit = max_pending_routes_per_target()
    pending = [item for _path, item in pending_route_records()]
    if target_limit > 0:
        target = route_capacity_key(route)
        pending_for_target = [
            item for item in pending
            if route_capacity_key(item) == target
        ]
        if len(pending_for_target) >= target_limit:
            raise SystemExit(
                "route capacity exceeded: "
                f"pending_routes_for_target={len(pending_for_target)} "
                f"target_site={target[0]} target_agent={target[1]} "
                f"max_pending_routes_per_target={target_limit}"
            )
    lane_limit = max_pending_routes_per_lane()
    if lane_limit > 0:
        lane = lane_capacity_key(route)
        pending_for_lane = [
            item for item in pending
            if lane_capacity_key(item) == lane
        ]
        if len(pending_for_lane) >= lane_limit:
            raise SystemExit(
                "route capacity exceeded: "
                f"pending_routes_for_lane={len(pending_for_lane)} "
                f"lane_id={lane} "
                f"max_pending_routes_per_lane={lane_limit}"
            )


def append_event(route: dict, event_type: str, **payload: object) -> None:
    event = {"ts": now(), "type": event_type}
    event.update({k: v for k, v in payload.items() if v is not None})
    route.setdefault("events", []).append(event)


def target_matches(route: dict, device_id: str) -> bool:
    target = route.get("target_site")
    if target == device_id:
        return True
    return device_id in DEVICE_ALIASES.get(str(target), set())


def cmd_create(args: argparse.Namespace) -> int:
    with locked():
        rid = args.route_id or make_route_id()
        status = args.status
        if status not in ("planned", "queued"):
            raise SystemExit("create status must be planned or queued")
        if route_path(rid):
            raise SystemExit(f"route already exists: {rid}")
        trace_id = resolve_trace_id(args.reply_to, args.trace_id, rid)
        lane_scope = resolve_lane_scope(
            reply_to=args.reply_to,
            trace_id=trace_id,
            route_id=rid,
            lane_id=args.lane_id,
            work_chat_id=args.work_chat_id,
            context_id=args.context_id,
        )
        route = {
            "route_id": rid,
            "trace_id": trace_id,
            "lane_id": lane_scope["lane_id"],
            "work_chat_id": lane_scope["work_chat_id"],
            "context_id": lane_scope["context_id"],
            "created_at": now(),
            "updated_at": now(),
            "created_by": args.created_by,
            "origin_site": args.origin_site,
            "origin_agent": args.origin_agent,
            "target_site": args.target_site,
            "target_agent": args.target_agent,
            "task_kind": args.task_kind,
            "title_original": args.title_original,
            "title_auto": args.title_auto or args.title_original,
            "required_capabilities": parse_csv_arg(args.capability),
            "constraints": parse_csv_arg(args.constraint) or ["read_only_first", "no_secrets"],
            "approval_required": args.approval_required,
            "secret_capabilities": parse_csv_arg(args.secret_capability),
            "status": status,
            "lease": None,
            "reply_to": args.reply_to,
            "artifacts_expected": parse_csv_arg(args.artifact_expected) or ["summary", "evidence"],
            "probe": args.probe,
            "cwd": args.cwd,
            "instructions": args.instructions,
            "events": [],
            "transparency": {
                "human_readable": True,
                "trace_required": True,
                "evidence_required": True,
                "secret_values_allowed": False,
            },
        }
        enforce_circuit_breaker("create")
        enforce_pending_capacity(route)
        append_event(route, "route_created", by=args.created_by, status=status)
        path = STATUS_DIRS[status] / f"{rid}.json"
        atomic_write(path, route)
    print(json.dumps({
        "route_id": rid,
        "trace_id": route["trace_id"],
        "lane_id": route["lane_id"],
        "work_chat_id": route.get("work_chat_id"),
        "context_id": route.get("context_id"),
        "path": str(path),
        "status": status,
    }, ensure_ascii=False))
    return 0


def create_route_record(
    *,
    route_id: str,
    trace_id: str | None,
    status: str,
    created_by: str,
    origin_site: str,
    origin_agent: str,
    target_site: str,
    target_agent: str,
    task_kind: str,
    title_original: str,
    title_auto: str | None,
    capabilities: list[str],
    constraints: list[str],
    approval_required: bool,
    secret_capabilities: list[str],
    reply_to: str | None,
    artifacts_expected: list[str],
    probe: str,
    cwd: str | None,
    instructions: str,
    lane_id: str | None = None,
    work_chat_id: str | None = None,
    context_id: str | None = None,
) -> tuple[Path, dict]:
    if status not in ("planned", "queued"):
        raise SystemExit("create status must be planned or queued")
    if route_path(route_id):
        raise SystemExit(f"route already exists: {route_id}")
    resolved_trace_id = resolve_trace_id(reply_to, trace_id, route_id)
    lane_scope = resolve_lane_scope(
        reply_to=reply_to,
        trace_id=resolved_trace_id,
        route_id=route_id,
        lane_id=lane_id,
        work_chat_id=work_chat_id,
        context_id=context_id,
    )
    route = {
        "route_id": route_id,
        "trace_id": resolved_trace_id,
        "lane_id": lane_scope["lane_id"],
        "work_chat_id": lane_scope["work_chat_id"],
        "context_id": lane_scope["context_id"],
        "created_at": now(),
        "updated_at": now(),
        "created_by": created_by,
        "origin_site": origin_site,
        "origin_agent": origin_agent,
        "target_site": target_site,
        "target_agent": target_agent,
        "task_kind": task_kind,
        "title_original": title_original,
        "title_auto": title_auto or title_original,
        "required_capabilities": capabilities,
        "constraints": constraints or ["read_only_first", "no_secrets"],
        "approval_required": approval_required,
        "secret_capabilities": secret_capabilities,
        "status": status,
        "lease": None,
        "reply_to": reply_to,
        "artifacts_expected": artifacts_expected or ["summary", "evidence"],
        "probe": probe,
        "cwd": cwd,
        "instructions": instructions,
        "events": [],
        "transparency": {
            "human_readable": True,
            "trace_required": True,
            "evidence_required": True,
            "secret_values_allowed": False,
        },
    }
    enforce_circuit_breaker("create")
    enforce_pending_capacity(route)
    append_event(route, "route_created", by=created_by, status=status)
    path = STATUS_DIRS[status] / f"{route_id}.json"
    atomic_write(path, route)
    return path, route


def cmd_list(args: argparse.Namespace) -> int:
    rows = []
    for path, route in iter_routes():
        if args.status and route.get("status") != args.status:
            continue
        if args.target_site and route.get("target_site") != args.target_site:
            continue
        if args.target_agent and route.get("target_agent") != args.target_agent:
            continue
        if args.trace_id and route.get("trace_id") != args.trace_id:
            continue
        if args.lane_id and route_lane_id(route) != args.lane_id:
            continue
        if args.work_chat_id and route.get("work_chat_id") != args.work_chat_id:
            continue
        if args.context_id and route.get("context_id") != args.context_id:
            continue
        route = dict(route)
        route["_path"] = str(path)
        rows.append(route)
    rows = rows[-args.limit :]
    if args.json:
        print(json.dumps(rows, ensure_ascii=False, indent=2))
        return 0
    print("CTX L2 Routes")
    if not rows:
        print("- none")
        return 0
    for route in rows[::-1]:
        print(
            f"- {route.get('route_id')} [{route.get('status')}] "
            f"lane={route_lane_id(route)} "
            f"{route.get('origin_site')} -> {route.get('target_site')} "
            f"{route.get('title_auto')}"
        )
    return 0


def _route_via(route: dict) -> str:
    reply = route.get("reply") or {}
    for e in (reply.get("evidence") or []):
        if isinstance(e, dict) and e.get("transport"):
            t = str(e.get("transport"))
            return "frp" if "frp" in t else t.split(":")[0][:8]
    return "local"


def _human_age(value: object) -> str:
    s = age_seconds(value)
    if s is None:
        return "-"
    if s < 60:
        return "%ds" % s
    if s < 3600:
        return "%dm" % (s // 60)
    if s < 86400:
        return "%dh" % (s // 3600)
    return "%dd" % (s // 86400)


def cmd_routes(args: argparse.Namespace) -> int:
    """Unified cross-device route board: 发起(origin) -> 执行(executor).
    Same view renders identically on both ends (single VPS ledger)."""
    rows = []
    for _path, route in iter_routes():
        if args.site and args.site not in (route.get("origin_site"), route.get("target_site")):
            continue
        if args.status and route.get("status") != args.status:
            continue
        rows.append(route)
    rows.sort(key=lambda r: str(r.get("created_at") or ""), reverse=True)
    rows = rows[: args.limit]
    if args.json:
        out = []
        for r in rows:
            reply = r.get("reply") or {}
            out.append({
                "route_id": r.get("route_id"),
                "status": r.get("status"),
                "origin": "%s:%s" % (r.get("origin_site"), r.get("origin_agent")),
                "executor": reply.get("executed_by") or ("%s:%s\u00b7pending" % (r.get("target_site"), r.get("target_agent"))),
                "via": _route_via(r),
                "task_kind": r.get("task_kind"),
                "verdict": (r.get("verification") or {}).get("verdict"),
                "created_at": r.get("created_at"),
                "title": r.get("title_auto") or r.get("title_original"),
            })
        print(json.dumps(out, ensure_ascii=False, indent=2))
        return 0
    self_site = args.self or args.site
    print("CTX Routes \u2014 \u7edf\u4e00\u901a\u884c\u8bb0\u5f55 (\u53d1\u8d77 origin \u2192 \u6267\u884c executor)")
    if self_site:
        print("  (\u672c\u7aef self=%s; \u2605=\u672c\u7aef\u53d1\u8d77)" % self_site)
    header = "%-2s %-9s %4s  %-22s %-24s %-5s %s" % ("", "STATUS", "AGE", "\u53d1\u8d77 origin", "\u6267\u884c executor", "VIA", "TITLE")
    print(header)
    if not rows:
        print("- none")
        return 0
    for r in rows:
        reply = r.get("reply") or {}
        origin = "%s:%s" % (r.get("origin_site"), r.get("origin_agent"))
        executor = reply.get("executed_by") or ("%s:%s\u00b7pending" % (r.get("target_site"), r.get("target_agent")))
        mark = "\u2605" if (self_site and r.get("origin_site") == self_site) else ""
        title = (r.get("title_auto") or r.get("title_original") or "")[:46]
        print("%-2s %-9s %4s  %-22s \u2192 %-24s %-5s %s" % (
            mark, str(r.get("status"))[:9], _human_age(r.get("created_at")),
            origin[:22], executor[:24], _route_via(r), title))
    return 0


def cmd_show(args: argparse.Namespace) -> int:
    _path, route = load_route(args.route_id)
    print(json.dumps(route, ensure_ascii=False, indent=2))
    return 0


def cmd_match(args: argparse.Namespace) -> int:
    _path, route = load_route(args.route_id)
    if route.get("status") != "queued":
        raise SystemExit(f"route not matchable: {args.route_id} status={route.get('status')}")
    report = match_report(route)
    print(json.dumps(report, ensure_ascii=False, indent=2))
    return 2 if report.get("unroutable_reason") else 0


def cmd_claim(args: argparse.Namespace) -> int:
    with locked():
        reconcile = reconcile_routes(by="ctx-route:claim-preflight")
        path, route = load_route(args.route_id)
        if route.get("status") != "queued":
            raise SystemExit(f"route not claimable: {args.route_id} status={route.get('status')}")
        if claim_instance_required() and not args.instance_id and not args.allow_missing_instance:
            raise SystemExit(f"route not claimable: {args.route_id} missing required claim instance_id")
        if not target_matches(route, args.device_id):
            raise SystemExit(f"device {args.device_id} cannot claim target {route.get('target_site')}")
        enforce_circuit_breaker("claim")
        enforce_claim_agent_code_current(
            device_id=args.device_id,
            agent_id=args.agent_id,
            instance_id=args.instance_id,
        )
        enforce_claim_capacity(route)
        expires = dt.datetime.now(dt.timezone.utc) + dt.timedelta(seconds=args.lease_seconds)
        lease_id = make_lease_id()
        claimed_at = now()
        route["lease"] = {
            "lease_id": lease_id,
            "claimed_by": args.agent_id,
            "claim_instance_id": args.instance_id,
            "device_id": args.device_id,
            "claimed_at": claimed_at,
            "expires_at": expires.replace(microsecond=0).isoformat().replace("+00:00", "Z"),
            "lease_seconds": args.lease_seconds,
        }
        route["lease"].update(claim_agent_profile_lease_fields(route, args.device_id, args.agent_id, claimed_at))
        event_fields = {
            "by": args.agent_id,
            "device_id": args.device_id,
            "instance_id": args.instance_id,
        }
        if route["lease"].get("agent_key"):
            event_fields["agent_key"] = route["lease"]["agent_key"]
        append_event(route, "route_claimed", **event_fields)
        new_path = move_route(path, route, "claimed")
    print(json.dumps({
        "route_id": args.route_id,
        "trace_id": route.get("trace_id"),
        "lane_id": route_lane_id(route),
        "status": "claimed",
        "path": str(new_path),
        "lease_id": lease_id,
        "reconciled_count": reconcile["action_count"],
    }, ensure_ascii=False))
    return 0


def cmd_release(args: argparse.Namespace) -> int:
    with locked():
        path, route = load_route(args.route_id)
        status = route.get("status")
        if status not in ACTIVE_STATUSES:
            raise SystemExit(f"route cannot release from status={status}")
        if status == "running" and not args.force:
            raise SystemExit("running route release requires --force after review")
        lease = route.get("lease") if isinstance(route.get("lease"), dict) else {}
        if not args.force:
            require_current_lease(
                route,
                agent_id=args.agent_id,
                instance_id=args.instance_id,
                lease_id=args.lease_id,
                action="release",
            )
        route["lease"] = None
        route["retry_count"] = int(route.get("retry_count") or 0) + 1
        append_event(
            route,
            "route_released",
            by=args.agent_id,
            instance_id=args.instance_id,
            reason=args.reason,
            retry_count=route["retry_count"],
        )
        new_path = move_route(path, route, "queued")
    print(json.dumps({
        "route_id": args.route_id,
        "status": "queued",
        "path": str(new_path),
        "retry_count": route["retry_count"],
    }, ensure_ascii=False))
    return 0


def cmd_start(args: argparse.Namespace) -> int:
    with locked():
        path, route = load_route(args.route_id)
        if route.get("status") != "claimed":
            raise SystemExit(f"route cannot start from status={route.get('status')}")
        require_current_lease(
            route,
            agent_id=args.agent_id,
            instance_id=args.instance_id,
            lease_id=args.lease_id,
            action="start",
        )
        append_event(route, "action_started", by=args.agent_id, instance_id=args.instance_id)
        new_path = move_route(path, route, "running")
    print(json.dumps({"route_id": args.route_id, "status": "running", "path": str(new_path)}, ensure_ascii=False))
    return 0


def cmd_reply(args: argparse.Namespace) -> int:
    with locked():
        path, route = load_route(args.route_id)
        if route.get("status") != "running":
            raise SystemExit(f"route cannot receive reply from status={route.get('status')}")
        reply = read_json_arg(args.reply_file)
        validate_reply_schema(reply, args.route_id)
        require_current_lease(
            route,
            agent_id=args.agent_id or reply.get("executed_by"),
            instance_id=args.instance_id,
            lease_id=args.lease_id,
            action="receive reply",
        )
        status = reply.get("status", "replied")
        route["reply"] = reply
        append_event(route, "result_replied", by=reply.get("executed_by"), status=status)
        new_path = move_route(path, route, status)
    print(json.dumps({"route_id": args.route_id, "status": status, "path": str(new_path)}, ensure_ascii=False))
    return 0


def reply_is_successful(route: dict) -> bool:
    reply = route.get("reply") if isinstance(route.get("reply"), dict) else {}
    return route.get("status") == "replied" and reply.get("status") == "replied"


def verification_status_for_verdict(verdict: str) -> str:
    if verdict == "accepted":
        return "verified"
    if verdict == "rejected":
        return "rejected"
    if verdict == "needs_followup":
        return "blocked"
    raise SystemExit(f"unsupported verification verdict: {verdict}")


def verification_target_status(route: dict, verdict: str) -> str:
    if route.get("status") not in UNVERIFIED_TERMINAL_STATUSES:
        raise SystemExit(f"route cannot be verified from status={route.get('status')}")
    if verdict == "accepted":
        if not reply_is_successful(route):
            raise SystemExit("route cannot be accepted without a successful replied result")
    return verification_status_for_verdict(verdict)


def verified_without_successful_reply(route: dict) -> bool:
    if route.get("status") != "verified":
        return False
    verification = route.get("verification") if isinstance(route.get("verification"), dict) else {}
    reply = route.get("reply") if isinstance(route.get("reply"), dict) else {}
    return verification.get("verdict") != "accepted" or reply.get("status") != "replied"


def apply_verification(path: Path, route: dict, verified_by: str, verdict: str, summary: str) -> Path:
    status = verification_target_status(route, verdict)
    route["verification"] = {
        "verified_at": now(),
        "verified_by": verified_by,
        "verdict": verdict,
        "summary": summary,
    }
    append_event(route, "verification_completed", by=verified_by, verdict=verdict)
    return move_route(path, route, status)


def apply_verification_correction(path: Path, route: dict, verified_by: str, verdict: str, summary: str) -> Path:
    status = verification_status_for_verdict(verdict)
    previous = route.get("verification") if isinstance(route.get("verification"), dict) else None
    if previous:
        route.setdefault("verification_history", []).append({
            "status_before": route.get("status"),
            "verification": previous,
            "reclassified_at": now(),
            "reclassified_by": verified_by,
            "reason": summary,
        })
    route["verification"] = {
        "verified_at": now(),
        "verified_by": verified_by,
        "verdict": verdict,
        "summary": summary,
    }
    append_event(route, "verification_reclassified", by=verified_by, verdict=verdict, reason=summary)
    return move_route(path, route, status)


def cmd_verify(args: argparse.Namespace) -> int:
    with locked():
        path, route = load_route(args.route_id)
        new_path = apply_verification(path, route, args.verified_by, args.verdict, args.summary)
        status = route.get("status")
    print(json.dumps({"route_id": args.route_id, "status": status, "path": str(new_path)}, ensure_ascii=False))
    return 0


def cmd_expire(args: argparse.Namespace) -> int:
    with locked():
        path, route = load_route(args.route_id)
        if route.get("status") in ("verified", "rejected", "cancelled"):
            raise SystemExit(f"route cannot expire from status={route.get('status')}")
        if route.get("status") in ACTIVE_STATUSES and not lease_expired(route) and not args.force:
            raise SystemExit("active route lease has not expired; use --force only after human review")
        append_event(route, "route_expired", by=args.by, reason=args.reason)
        new_path = move_route(path, route, "expired")
    print(json.dumps({"route_id": args.route_id, "status": "expired", "path": str(new_path)}, ensure_ascii=False))
    return 0


def cmd_cancel(args: argparse.Namespace) -> int:
    with locked():
        path, route = load_route(args.route_id)
        if route.get("status") in ("verified", "rejected", "cancelled"):
            raise SystemExit(f"route cannot cancel from status={route.get('status')}")
        append_event(route, "route_cancelled", by=args.by, reason=args.reason)
        new_path = move_route(path, route, "cancelled")
    print(json.dumps({"route_id": args.route_id, "status": "cancelled", "path": str(new_path)}, ensure_ascii=False))
    return 0


def cmd_requeue(args: argparse.Namespace) -> int:
    with locked():
        path, route = load_route(args.route_id)
        status = route.get("status")
        if status in ("queued", "planned"):
            raise SystemExit(f"route already queue-like: status={status}")
        if status in ("verified", "rejected", "replied", "needs_approval", "cancelled"):
            raise SystemExit(f"route cannot requeue from status={status}")
        if status in ACTIVE_STATUSES and not lease_expired(route) and not args.force:
            raise SystemExit("active route lease has not expired; use --force only after human review")
        if route.get("verification") and not args.force:
            raise SystemExit("verified terminal route requires --force to requeue")
        route["lease"] = None
        route["retry_count"] = int(route.get("retry_count") or 0) + 1
        append_event(route, "route_requeued", by=args.by, reason=args.reason, retry_count=route["retry_count"])
        new_path = move_route(path, route, "queued")
    print(json.dumps({"route_id": args.route_id, "status": "queued", "path": str(new_path), "retry_count": route["retry_count"]}, ensure_ascii=False))
    return 0


def cmd_device_upsert(args: argparse.Namespace) -> int:
    with locked():
        profile = read_json_arg(args.profile_file)
        device_id = profile.get("device_id")
        if not device_id:
            raise SystemExit("device profile missing device_id")
        path = DEVICES / f"{device_id}.json"
        if path.exists():
            existing = json.loads(path.read_text(encoding="utf-8"))
            for key in ("agents", "capabilities", "transports", "red_lines"):
                merged = []
                for item in [*(existing.get(key) or []), *(profile.get(key) or [])]:
                    if item not in merged:
                        merged.append(item)
                if merged:
                    profile[key] = merged
        profile["last_seen"] = now()
        atomic_write(path, profile)
    print(json.dumps({"device_id": device_id, "path": str(path), "last_seen": profile["last_seen"]}, ensure_ascii=False))
    return 0


def agent_instance_path_under(base: Path, device_id: str, agent_id: str, instance_id: str) -> Path:
    name = "__".join(safe_record_id(part) for part in (device_id, agent_id, instance_id))
    return base / "devices" / "agent-instances" / f"{name}.json"


def agent_instance_path(device_id: str, agent_id: str, instance_id: str) -> Path:
    return agent_instance_path_under(BASE, device_id, agent_id, instance_id)


def route_call_metric_path(device_id: str, agent_id: str, instance_id: str, event_id: str) -> Path:
    name = "__".join(safe_record_id(part) for part in (device_id, agent_id, instance_id, event_id))
    return ROUTE_CALL_METRICS / f"{name}.json"


def stable_metric_event_id(identity: dict) -> str:
    text = json.dumps(identity, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
    return hashlib.sha256(text.encode("utf-8")).hexdigest()


def persist_route_call_metrics(args: argparse.Namespace, metrics: dict, seen_at: str) -> list[dict]:
    recent = metrics.get("recent") if isinstance(metrics.get("recent"), list) else []
    written = []
    for index, item in enumerate(recent):
        if not isinstance(item, dict):
            continue
        elapsed_ms = item.get("elapsed_ms")
        if not isinstance(elapsed_ms, int):
            continue
        operation = str(item.get("operation") or "unknown")
        attempts = item.get("attempts")
        ok = item.get("ok")
        observed_at = item.get("observed_at") if parse_time(item.get("observed_at")) else None
        identity = {
            "device_id": args.device_id,
            "agent_id": args.agent_id,
            "instance_id": args.instance_id,
            "operation": operation,
            "elapsed_ms": elapsed_ms,
            "ok": ok if isinstance(ok, bool) else None,
            "attempts": attempts if isinstance(attempts, int) else None,
            "observed_at": observed_at,
        }
        if observed_at is None:
            identity["recent_index_without_observed_at"] = index
        event_id = stable_metric_event_id(identity)
        path = route_call_metric_path(args.device_id, args.agent_id, args.instance_id, event_id)
        record = {
            "schema": "ctx-route-call-metric-v1",
            "event_id": event_id,
            "device_id": args.device_id,
            "agent_id": args.agent_id,
            "instance_id": args.instance_id,
            "pid": args.pid,
            "hostname": args.hostname,
            "started_at": args.started_at,
            "state": args.state,
            "operation": operation,
            "elapsed_ms": elapsed_ms,
            "ok": ok if isinstance(ok, bool) else None,
            "attempts": attempts if isinstance(attempts, int) else None,
            "observed_at": observed_at,
            "heartbeat_seen_at": seen_at,
            "source": "agent-heartbeat.metrics.recent",
        }
        record = {key: value for key, value in record.items() if value is not None}
        if not path.exists():
            atomic_write(path, record)
            written.append({"event_id": event_id, "path": str(path)})
    return written


def cmd_agent_heartbeat(args: argparse.Namespace) -> int:
    with locked():
        seen_at = now()
        profile = {
            "device_id": args.device_id,
            "agent_id": args.agent_id,
            "instance_id": args.instance_id,
            "pid": args.pid,
            "hostname": args.hostname,
            "started_at": args.started_at,
            "role": args.role,
            "state": args.state,
            "heartbeat_kind": "ctx-agent-instance",
            "last_seen": seen_at,
        }
        code = {
            "tool_path": args.tool_path,
            "sha256": args.tool_sha256,
            "mtime": args.tool_mtime,
            "loaded_sha256": args.loaded_tool_sha256,
            "loaded_mtime": args.loaded_tool_mtime,
            "error": args.tool_error,
        }
        code = {key: value for key, value in code.items() if value}
        if code:
            profile["agent_code"] = code
        if args.state == "stopped":
            profile["stopped_at"] = seen_at
        metric_events_written = []
        if args.metrics_json:
            profile["metrics"] = read_json_text(args.metrics_json, "metrics-json")
            metric_events_written = persist_route_call_metrics(args, profile["metrics"], seen_at)
        path = agent_instance_path(args.device_id, args.agent_id, args.instance_id)
        if path.exists():
            try:
                existing = json.loads(path.read_text(encoding="utf-8"))
            except Exception:
                existing = {}
            profile["first_seen"] = existing.get("first_seen") or seen_at
        else:
            profile["first_seen"] = seen_at
        atomic_write(path, profile)
    print(json.dumps({
        "device_id": args.device_id,
        "agent_id": args.agent_id,
        "instance_id": args.instance_id,
        "path": str(path),
        "state": profile["state"],
        "last_seen": profile["last_seen"],
        "metric_events_written": len(metric_events_written),
    }, ensure_ascii=False))
    return 0


def cmd_devices(args: argparse.Namespace) -> int:
    ensure_dirs()
    rows = []
    for path in sorted(DEVICES.glob("*.json")):
        try:
            profile = json.loads(path.read_text(encoding="utf-8"))
            profile["_path"] = str(path)
            rows.append(profile)
        except Exception as exc:
            rows.append({"device_id": path.stem, "error": str(exc)})
    if args.json:
        print(json.dumps(rows, ensure_ascii=False, indent=2))
        return 0
    print("CTX Devices")
    if not rows:
        print("- none")
        return 0
    for profile in rows:
        print(f"- {profile.get('device_id')} os={profile.get('os')} health={profile.get('health')} last_seen={profile.get('last_seen')}")
    return 0


def cmd_agent_register(args: argparse.Namespace) -> int:
    with locked():
        result = register_agent_profile(read_json_arg(args.profile_file))
    print(json.dumps(result, ensure_ascii=False))
    return 0


def cmd_agent_show(args: argparse.Namespace) -> int:
    profile = load_agent_profile(args.agent_key)
    if not profile:
        print(f"no profile for agent_key: {args.agent_key}", file=sys.stderr)
        return 1
    print(json.dumps(profile, ensure_ascii=False, indent=2))
    return 0


def cmd_agent_list(args: argparse.Namespace) -> int:
    rows = list_agent_profiles()
    if args.json:
        print(json.dumps(rows, ensure_ascii=False, indent=2))
        return 0
    print(f"CTX Agent Profiles — {len(rows)} agent(s)")
    if not rows:
        print("- none")
        return 0
    for profile in rows:
        engine = profile.get("engine") if isinstance(profile.get("engine"), dict) else {}
        print(
            f"- {profile.get('agent_key')} "
            f"id={profile.get('agent_id')} "
            f"kind={profile.get('kind')} "
            f"engine={engine.get('name', '?')}/{engine.get('version', '?')}"
        )
    return 0


def cmd_policy(args: argparse.Namespace) -> int:
    with locked():
        policy = load_policy()
        changed = False
        if args.claim_instance_required is not None:
            policy["claim_instance_required"] = parse_bool_text(args.claim_instance_required, "--claim-instance-required")
            changed = True
        if args.claim_agent_code_current_required is not None:
            policy["claim_agent_code_current_required"] = parse_bool_text(
                args.claim_agent_code_current_required,
                "--claim-agent-code-current-required",
            )
            changed = True
        if args.max_active_routes_total is not None:
            policy["max_active_routes_total"] = parse_non_negative_int(
                args.max_active_routes_total,
                "--max-active-routes-total",
            )
            changed = True
        if args.max_active_routes_per_target is not None:
            policy["max_active_routes_per_target"] = parse_non_negative_int(
                args.max_active_routes_per_target,
                "--max-active-routes-per-target",
            )
            changed = True
        if args.max_active_routes_per_lane is not None:
            policy["max_active_routes_per_lane"] = parse_non_negative_int(
                args.max_active_routes_per_lane,
                "--max-active-routes-per-lane",
            )
            changed = True
        if args.max_pending_routes_per_target is not None:
            policy["max_pending_routes_per_target"] = parse_non_negative_int(
                args.max_pending_routes_per_target,
                "--max-pending-routes-per-target",
            )
            changed = True
        if args.max_pending_routes_per_lane is not None:
            policy["max_pending_routes_per_lane"] = parse_non_negative_int(
                args.max_pending_routes_per_lane,
                "--max-pending-routes-per-lane",
            )
            changed = True
        if args.circuit_breaker_enabled is not None:
            policy["circuit_breaker_enabled"] = parse_bool_text(
                args.circuit_breaker_enabled,
                "--circuit-breaker-enabled",
            )
            changed = True
        if args.circuit_breaker_open_on_doctor_critical is not None:
            policy["circuit_breaker_open_on_doctor_critical"] = parse_bool_text(
                args.circuit_breaker_open_on_doctor_critical,
                "--circuit-breaker-open-on-doctor-critical",
            )
            changed = True
        if args.circuit_breaker_open_on_doctor_warn is not None:
            policy["circuit_breaker_open_on_doctor_warn"] = parse_bool_text(
                args.circuit_breaker_open_on_doctor_warn,
                "--circuit-breaker-open-on-doctor-warn",
            )
            changed = True
        if args.circuit_breaker_max_active_routes is not None:
            policy["circuit_breaker_max_active_routes"] = parse_non_negative_int(
                args.circuit_breaker_max_active_routes,
                "--circuit-breaker-max-active-routes",
            )
            changed = True
        if args.circuit_breaker_max_pending_routes is not None:
            policy["circuit_breaker_max_pending_routes"] = parse_non_negative_int(
                args.circuit_breaker_max_pending_routes,
                "--circuit-breaker-max-pending-routes",
            )
            changed = True
        policy.setdefault("claim_instance_required", False)
        policy.setdefault("claim_agent_code_current_required", True)
        policy.setdefault("max_active_routes_total", DEFAULT_MAX_ACTIVE_ROUTES_TOTAL)
        policy.setdefault("max_active_routes_per_target", DEFAULT_MAX_ACTIVE_ROUTES_PER_TARGET)
        policy.setdefault("max_active_routes_per_lane", DEFAULT_MAX_ACTIVE_ROUTES_PER_LANE)
        policy.setdefault("max_pending_routes_per_target", DEFAULT_MAX_PENDING_ROUTES_PER_TARGET)
        policy.setdefault("max_pending_routes_per_lane", DEFAULT_MAX_PENDING_ROUTES_PER_LANE)
        policy.setdefault("circuit_breaker_enabled", DEFAULT_CIRCUIT_BREAKER_ENABLED)
        policy.setdefault(
            "circuit_breaker_open_on_doctor_critical",
            DEFAULT_CIRCUIT_BREAKER_OPEN_ON_DOCTOR_CRITICAL,
        )
        policy.setdefault(
            "circuit_breaker_open_on_doctor_warn",
            DEFAULT_CIRCUIT_BREAKER_OPEN_ON_DOCTOR_WARN,
        )
        policy.setdefault("circuit_breaker_max_active_routes", DEFAULT_CIRCUIT_BREAKER_MAX_ACTIVE_ROUTES)
        policy.setdefault("circuit_breaker_max_pending_routes", DEFAULT_CIRCUIT_BREAKER_MAX_PENDING_ROUTES)
        if changed:
            policy["updated_at"] = now()
            policy["updated_by"] = args.updated_by
            atomic_write(POLICY, policy)
    if args.json:
        print(json.dumps(policy, ensure_ascii=False, indent=2, sort_keys=True))
    else:
        print("CTX Route Policy")
        print(f"- claim_instance_required: {policy.get('claim_instance_required')}")
        print(f"- claim_agent_code_current_required: {policy.get('claim_agent_code_current_required')}")
        print(f"- max_active_routes_total: {policy.get('max_active_routes_total')}")
        print(f"- max_active_routes_per_target: {policy.get('max_active_routes_per_target')}")
        print(f"- max_active_routes_per_lane: {policy.get('max_active_routes_per_lane')}")
        print(f"- max_pending_routes_per_target: {policy.get('max_pending_routes_per_target')}")
        print(f"- max_pending_routes_per_lane: {policy.get('max_pending_routes_per_lane')}")
        print(f"- circuit_breaker_enabled: {policy.get('circuit_breaker_enabled')}")
        print(f"- circuit_breaker_open_on_doctor_critical: {policy.get('circuit_breaker_open_on_doctor_critical')}")
        print(f"- circuit_breaker_open_on_doctor_warn: {policy.get('circuit_breaker_open_on_doctor_warn')}")
        print(f"- circuit_breaker_max_active_routes: {policy.get('circuit_breaker_max_active_routes')}")
        print(f"- circuit_breaker_max_pending_routes: {policy.get('circuit_breaker_max_pending_routes')}")
        if policy.get("updated_at"):
            print(f"- updated_at: {policy.get('updated_at')}")
        if policy.get("updated_by"):
            print(f"- updated_by: {policy.get('updated_by')}")
    return 0


def circuit_breaker_doctor_args(args: argparse.Namespace) -> argparse.Namespace:
    return argparse.Namespace(
        json=True,
        strict=False,
        queued_warn_seconds=args.queued_warn_seconds,
        unverified_warn_seconds=args.unverified_warn_seconds,
        device_stale_seconds=args.device_stale_seconds,
        agent_stale_seconds=args.agent_stale_seconds,
        agent_latency_warn_ms=args.agent_latency_warn_ms,
        agent_latency_observed_after=args.agent_latency_observed_after,
        claim_instance_required_after=args.claim_instance_required_after,
        agent_code_required_after=args.agent_code_required_after,
        include_metric_events=args.include_metric_events,
        task_link_limit=20,
        transport_probe=args.transport_probe or [],
        transport_probe_timeout=args.transport_probe_timeout,
    )


def evaluate_circuit_breaker(args: argparse.Namespace) -> dict:
    reference = utc_now()
    active = active_route_records(reference)
    pending = pending_route_records()
    active_limit = (
        parse_non_negative_int(args.active_routes_limit, "--active-routes-limit")
        if args.active_routes_limit is not None
        else circuit_breaker_max_active_routes()
    )
    pending_limit = (
        parse_non_negative_int(args.pending_routes_limit, "--pending-routes-limit")
        if args.pending_routes_limit is not None
        else circuit_breaker_max_pending_routes()
    )
    trips = []
    if active_limit > 0 and len(active) >= active_limit:
        trips.append({
            "kind": "active_routes_threshold",
            "severity": "critical",
            "summary": (
                f"active_routes={len(active)} reached "
                f"circuit_breaker_max_active_routes={active_limit}"
            ),
            "active_routes": len(active),
            "threshold": active_limit,
        })
    if pending_limit > 0 and len(pending) >= pending_limit:
        trips.append({
            "kind": "pending_routes_threshold",
            "severity": "warn",
            "summary": (
                f"pending_routes={len(pending)} reached "
                f"circuit_breaker_max_pending_routes={pending_limit}"
            ),
            "pending_routes": len(pending),
            "threshold": pending_limit,
        })

    doctor = None
    if not args.skip_doctor:
        doctor = doctor_report(circuit_breaker_doctor_args(args), include_circuit_breaker=False)
        current_counts = doctor.get("current_issue_counts") or {}
        critical_count = int(current_counts.get("critical") or 0)
        warn_count = int(current_counts.get("warn") or 0)
        if circuit_breaker_open_on_doctor_critical() and critical_count:
            trips.append({
                "kind": "doctor_current_critical",
                "severity": "critical",
                "summary": f"doctor reports {critical_count} current critical issue(s)",
                "count": critical_count,
            })
        if (args.doctor_warn or circuit_breaker_open_on_doctor_warn()) and warn_count:
            trips.append({
                "kind": "doctor_current_warn",
                "severity": "warn",
                "summary": f"doctor reports {warn_count} current warn issue(s)",
                "count": warn_count,
            })

    should_trip = bool(trips)
    severity = "critical" if any(item.get("severity") == "critical" for item in trips) else "warn"
    trip = {
        "kind": "circuit_breaker_evaluation",
        "evaluated_at": now(),
        "should_open": should_trip,
        "severity": severity if should_trip else None,
        "trips": trips,
        "active_routes": len(active),
        "pending_routes": len(pending),
        "policy": circuit_breaker_policy_snapshot(),
    }
    state = load_circuit_breaker()
    if args.open and should_trip:
        reason = args.reason or "; ".join(item["summary"] for item in trips)
        state = circuit_breaker_open(reason, by=args.by, severity=severity, trip=trip)
    else:
        state["last_evaluated_at"] = trip["evaluated_at"]
        state["last_evaluation"] = trip
        if args.open:
            state["updated_at"] = trip["evaluated_at"]
            state["updated_by"] = args.by
        write_circuit_breaker(state)
        state = load_circuit_breaker()
    return {
        "generated_at": now(),
        "state": circuit_breaker_public_state(),
        "evaluation": trip,
        "doctor": doctor,
    }


def print_circuit_breaker_text(result: dict) -> None:
    state = result.get("state") if isinstance(result.get("state"), dict) else result
    print(
        "CTX Circuit Breaker "
        f"state={state.get('state')} enabled={state.get('enabled')} "
        f"severity={state.get('severity') or 'none'}"
    )
    if state.get("reason"):
        print(f"- reason: {state.get('reason')}")
    if state.get("opened_at"):
        print(f"- opened_at: {state.get('opened_at')} by={state.get('opened_by')}")
    if state.get("closed_at"):
        print(f"- closed_at: {state.get('closed_at')} by={state.get('closed_by')}")
    evaluation = result.get("evaluation") if isinstance(result, dict) else None
    if evaluation:
        print(
            f"- evaluated_at: {evaluation.get('evaluated_at')} "
            f"should_open={evaluation.get('should_open')} "
            f"active={evaluation.get('active_routes')} pending={evaluation.get('pending_routes')}"
        )
        for trip in evaluation.get("trips") or []:
            print(f"- {trip.get('severity').upper()} {trip.get('kind')}: {trip.get('summary')}")


def cmd_circuit_breaker(args: argparse.Namespace) -> int:
    if args.circuit_breaker_cmd == "status":
        state = circuit_breaker_public_state()
        if args.json:
            print(json.dumps(state, ensure_ascii=False, indent=2, sort_keys=True))
        else:
            print_circuit_breaker_text(state)
        return 0

    if args.circuit_breaker_cmd == "open":
        with locked():
            state = circuit_breaker_open(args.reason, by=args.by, severity=args.severity)
        if args.json:
            print(json.dumps(state, ensure_ascii=False, indent=2, sort_keys=True))
        else:
            print_circuit_breaker_text(state)
        return 0

    if args.circuit_breaker_cmd == "close":
        with locked():
            state = circuit_breaker_close(args.reason, by=args.by)
        if args.json:
            print(json.dumps(state, ensure_ascii=False, indent=2, sort_keys=True))
        else:
            print_circuit_breaker_text(state)
        return 0

    if args.circuit_breaker_cmd == "evaluate":
        with locked():
            result = evaluate_circuit_breaker(args)
        if args.json:
            print(json.dumps(result, ensure_ascii=False, indent=2, sort_keys=True))
        else:
            print_circuit_breaker_text(result)
        return 2 if args.strict and result["state"].get("state") == "open" else 0

    raise SystemExit(f"unknown circuit breaker command: {args.circuit_breaker_cmd}")


def cmd_reconcile(args: argparse.Namespace) -> int:
    with locked():
        report = reconcile_routes(
            max_retries=args.max_retries,
            dry_run=args.dry_run,
            by=args.by,
            queued_warn_seconds=args.queued_warn_seconds,
            unverified_warn_seconds=args.unverified_warn_seconds,
            terminal_verdict=args.terminal_verdict,
            invalid_verified_verdict=args.invalid_verified_verdict,
            stale_queued_action=args.stale_queued_action,
            audit_run_id=args.audit_run_id,
        )
    if args.json:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    else:
        mode = "dry-run" if report["dry_run"] else "apply"
        print(f"CTX Route Reconcile [{mode}] generated_at={report['generated_at']}")
        print(
            f"actions={report['action_count']} observations={report['observation_count']} "
            f"audit_run_id={report.get('audit_run_id')}"
        )
        for action in report["actions"]:
            print(
                f"- {action.get('action')} {action.get('route_id')} "
                f"from={action.get('from_status')} to={action.get('to_status')} "
                f"verdict={action.get('verdict')} retry={action.get('retry_count')} "
                f"reason={action.get('reason')}"
            )
        for observation in report["observations"][:50]:
            print(
                f"- observe {observation.get('kind')} {observation.get('route_id')} "
                f"status={observation.get('status')} age={observation.get('age_seconds')}"
            )
    if args.strict and (
        report["action_count"] > 0
        or any(item.get("kind") == "unverified_terminal_route" for item in report.get("observations") or [])
    ):
        return 2
    return 0


def read_nested_field(data: dict, field_path: object) -> object:
    current: object = data
    for part in str(field_path or "").split("."):
        if not part:
            continue
        if not isinstance(current, dict):
            return None
        current = current.get(part)
    return current


def read_safe_task_json(path_value: object, audit_profile: dict | None = None) -> dict:
    if not isinstance(path_value, str):
        return {"path": path_value, "exists": False, "read": False}
    profile = audit_profile if isinstance(audit_profile, dict) else default_audit_profile()
    path = Path(path_value)
    out = {"path": path_value, "exists": path.exists(), "read": False}
    if not path.exists() or path.suffix != ".json" or not under_path(path, DONE):
        return out
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception as exc:
        out["error"] = str(exc)
        return out
    thread = read_nested_field(data, profile.get("thread_field"))
    thread = thread if isinstance(thread, dict) else {}
    thread_id = read_nested_field(thread, profile.get("thread_id_field")) if thread else None
    thread_model = read_nested_field(thread, profile.get("thread_model_field")) if thread else None
    out.update({
        "read": True,
        "task_id": data.get("task_id"),
        "status": data.get("status"),
        "verdict": data.get("verdict"),
        "route_id": data.get("route_id"),
        "created_at": data.get("created_at"),
        "updated_at": data.get("updated_at"),
        "started_at": data.get("started_at"),
        "finished_at": data.get("finished_at"),
        "summary": safe_text(data.get("summary")),
    })
    thread_id_output = str(profile.get("thread_id_output_field") or "thread_id").strip()
    thread_model_output = str(profile.get("thread_model_output_field") or "thread_model").strip()
    if thread_id_output and thread_id is not None:
        out[thread_id_output] = thread_id
    if thread_model_output and thread_model is not None:
        out[thread_model_output] = thread_model
    return out


def route_task_links(route: dict, audit_profile: dict | None = None) -> list[dict]:
    reply = route.get("reply") if isinstance(route.get("reply"), dict) else {}
    profile = audit_profile
    if not isinstance(profile, dict):
        profile, _issues = route_audit_context(route)
    links: list[dict] = []
    seen: dict[tuple[object, object], dict] = {}

    def add(link: dict) -> None:
        key = (link.get("task_id"), link.get("path") or link.get("output_path"))
        if key in seen:
            seen[key].update({k: v for k, v in link.items() if v is not None})
            return
        seen[key] = link
        links.append(link)

    for evidence in reply.get("evidence") or []:
        if not isinstance(evidence, dict):
            continue
        task_id = evidence.get("task_id")
        result_path = evidence.get("result_path")
        if task_id or result_path:
            add({
                "source": "reply.evidence",
                "kind": evidence.get("kind"),
                "task_id": task_id,
                "path": result_path,
                "ctx_status": evidence.get("ctx_status"),
                "verdict": evidence.get("verdict"),
            })
        output_path = evidence.get("output_path")
        if output_path:
            add({
                "source": "reply.evidence",
                "kind": evidence.get("kind"),
                "output_path": output_path,
                "session_visibility": evidence.get("session_visibility"),
            })

    for artifact in reply.get("artifacts") or []:
        if not isinstance(artifact, dict):
            continue
        path_value = artifact.get("path")
        task = read_safe_task_json(path_value, profile)
        link = {
            "source": "reply.artifacts",
            "kind": artifact.get("kind"),
            "path": path_value,
            "exists": task.get("exists"),
            "read": task.get("read"),
            "task_id": task.get("task_id"),
            "status": task.get("status"),
            "verdict": task.get("verdict"),
        }
        for key in (profile.get("thread_id_output_field"), profile.get("thread_model_output_field"), "thread_id", "thread_model"):
            if key and task.get(key) is not None:
                link[str(key)] = task.get(key)
        add(link)
    return links


def route_reply_shape_kind(route: dict) -> str | None:
    reply = route.get("reply") if isinstance(route.get("reply"), dict) else {}
    schema = str(reply.get("schema") or "").strip()
    if schema:
        return schema
    result_kind = str(reply.get("result_kind") or "").strip()
    if result_kind:
        return result_kind
    return None


def route_reply_has_evidence_kind(route: dict, kind: str) -> bool:
    reply = route.get("reply") if isinstance(route.get("reply"), dict) else {}
    expected = str(kind or "").strip()
    if not expected:
        return False
    for evidence in reply.get("evidence") or []:
        if isinstance(evidence, dict) and str(evidence.get("kind") or "").strip() == expected:
            return True
    return False


def profile_for_agent_id(agent_id: str) -> dict | None:
    matches = agent_profiles_by_agent_id().get(str(agent_id or "").strip()) or []
    return matches[0] if len(matches) == 1 else None


def agent_key_for_reply(route: dict) -> str | None:
    reply = route.get("reply") if isinstance(route.get("reply"), dict) else {}
    executed_by = str(reply.get("executed_by") or "").strip()
    if not executed_by:
        return None
    profile = profile_for_agent_id(executed_by)
    if not isinstance(profile, dict):
        return None
    agent_key = str(profile.get("agent_key") or "").strip()
    return agent_key or None


def route_audit_profile_snapshot(route: dict) -> dict | None:
    candidates = [
        route.get("audit_profile_snapshot"),
        route.get("claim_audit_profile"),
    ]
    lease = route.get("lease") if isinstance(route.get("lease"), dict) else {}
    candidates.extend([
        lease.get("audit_profile_snapshot"),
        lease.get("claim_audit_profile"),
    ])
    claim_profile = lease.get("agent_profile") if isinstance(lease.get("agent_profile"), dict) else {}
    candidates.append(claim_profile.get("audit_profile"))
    for candidate in candidates:
        if isinstance(candidate, dict):
            merged = default_audit_profile()
            merged.update(candidate)
            return merged
    return None


def route_audit_context(route: dict) -> tuple[dict, list[dict]]:
    rid = route.get("route_id")
    issues: list[dict] = []
    snapshot = route_audit_profile_snapshot(route)
    if snapshot:
        return snapshot, issues
    reply = route.get("reply") if isinstance(route.get("reply"), dict) else {}
    executed_by = str(reply.get("executed_by") or "").strip()
    verified_history = bool(route.get("verification"))
    if executed_by and verified_history:
        issues.append(issue(
            "info",
            "missing_audit_profile_snapshot",
            "route has no claim-time audit_profile snapshot; doctor used strict default",
            rid,
            executed_by=executed_by,
        ))
        return default_audit_profile(), issues
    if executed_by:
        profile = profile_for_agent_id(executed_by)
        if isinstance(profile, dict):
            audit_profile = profile.get("audit_profile") if isinstance(profile.get("audit_profile"), dict) else {}
            merged = default_audit_profile()
            merged.update(audit_profile)
            issues.append(issue(
                "info",
                "live_audit_profile_unpinned",
                "route has no claim-time audit_profile snapshot; doctor used the current registered profile",
                rid,
                executed_by=executed_by,
                agent_key=profile.get("agent_key"),
            ))
            return merged, issues
    if executed_by:
        issues.append(issue(
            "warn",
            "unknown_audit_profile",
            "route executor has no resolvable registered audit_profile; doctor used strict default",
            rid,
            executed_by=executed_by,
        ))
    return default_audit_profile(), issues


def route_public_view(path: Path, route: dict, inclusion_reason: str | None = None) -> dict:
    reply = route.get("reply") or {}
    view = {
        "route_id": route.get("route_id"),
        "trace_id": route.get("trace_id") or route.get("route_id"),
        "lane_id": route_lane_id(route),
        "work_chat_id": route.get("work_chat_id"),
        "context_id": route.get("context_id"),
        "inclusion_reason": inclusion_reason,
        "status": route.get("status"),
        "path": str(path),
        "origin": f"{route.get('origin_site')}:{route.get('origin_agent')}",
        "target": f"{route.get('target_site')}:{route.get('target_agent')}",
        "task_kind": route.get("task_kind"),
        "title": route.get("title_auto") or route.get("title_original"),
        "reply_to": route.get("reply_to"),
        "created_at": route.get("created_at"),
        "updated_at": route.get("updated_at"),
        "events": route.get("events") or [],
        "reply": {
            "status": reply.get("status"),
            "executed_by": reply.get("executed_by"),
            "summary": safe_text(reply.get("summary")),
            "secret_events": reply.get("secret_events") or [],
            "residual_risk": safe_text(reply.get("residual_risk")),
            "artifacts": reply.get("artifacts") or [],
            "evidence_kinds": [item.get("kind") for item in (reply.get("evidence") or []) if isinstance(item, dict)],
            "task_refs": route_task_links(route),
        } if reply else None,
        "verification": route.get("verification"),
    }
    return view


def under_path(path: Path, base: Path) -> bool:
    try:
        path.resolve().relative_to(base.resolve())
        return True
    except ValueError:
        return False


def task_summary_from_artifact(artifact: dict) -> dict:
    path_value = artifact.get("path")
    out = {
        "kind": artifact.get("kind"),
        "path": path_value,
        "exists": False,
        "read": False,
    }
    if not isinstance(path_value, str):
        return out
    path = Path(path_value)
    out["exists"] = path.exists()
    if not path.exists() or path.suffix != ".json" or not under_path(path, DONE):
        return out
    try:
        out.update(read_safe_task_json(path_value, default_audit_profile()))
    except Exception as exc:
        out["error"] = str(exc)
    return out


def trace_routes(root: dict) -> tuple[list[tuple[Path, dict, str]], list[dict]]:
    trace_id = root.get("trace_id") or root.get("route_id")
    all_routes = iter_routes()
    route_by_id = {route.get("route_id"): (path, route) for path, route in all_routes if route.get("route_id")}
    selected: dict[str, tuple[Path, dict, str]] = {}
    warnings: list[dict] = []

    def add(path: Path, route: dict, reason: str) -> bool:
        rid = route.get("route_id")
        if not rid or rid in selected:
            return False
        selected[rid] = (path, route, reason)
        return True

    root_id = root.get("route_id")
    if root_id in route_by_id:
        add(*route_by_id[root_id], "root")
    for path, route in all_routes:
        if route.get("trace_id") == trace_id:
            add(path, route, "trace_id")
    queue = list(selected)
    while queue:
        current = queue.pop(0)
        for path, route in all_routes:
            rid = route.get("route_id")
            if rid in selected:
                continue
            if route.get("reply_to") != current:
                continue
            route_trace_id = route.get("trace_id")
            if route_trace_id == trace_id:
                if add(path, route, "reply_to"):
                    queue.append(rid)
            elif route_trace_id is None:
                if add(path, route, "legacy_reply_to"):
                    queue.append(rid)
            else:
                warnings.append({
                    "kind": "cross_trace_reply_to",
                    "route_id": rid,
                    "reply_to": current,
                    "route_trace_id": route_trace_id,
                    "root_trace_id": trace_id,
                })
    root_reply_to = root.get("reply_to")
    if root_reply_to and root_reply_to in route_by_id:
        _parent_path, parent = route_by_id[root_reply_to]
        parent_trace_id = parent.get("trace_id")
        if parent_trace_id and parent_trace_id != trace_id:
            warnings.append({
                "kind": "root_cross_trace_parent",
                "route_id": root_id,
                "reply_to": root_reply_to,
                "parent_trace_id": parent_trace_id,
                "root_trace_id": trace_id,
            })
        elif parent_trace_id is None and root.get("trace_id"):
            warnings.append({
                "kind": "root_legacy_parent_not_merged",
                "route_id": root_id,
                "reply_to": root_reply_to,
                "root_trace_id": trace_id,
            })
    return sorted(selected.values(), key=lambda item: item[1].get("created_at") or ""), warnings


def cmd_trace(args: argparse.Namespace) -> int:
    root_path, root = load_route(args.route_id)
    root = normalize_route(root)
    routes, warnings = trace_routes(root)
    output_routes = []
    tasks = []
    for path, route, reason in routes:
        view = route_public_view(path, normalize_route(route), reason)
        output_routes.append(view)
        for artifact in ((route.get("reply") or {}).get("artifacts") or []):
            task = task_summary_from_artifact(artifact)
            if task.get("read") or task.get("exists"):
                tasks.append(task)
    trace = {
        "trace_id": root.get("trace_id") or root.get("route_id"),
        "lane_id": route_lane_id(root),
        "work_chat_id": root.get("work_chat_id"),
        "context_id": root.get("context_id"),
        "root_route_id": args.route_id,
        "root_path": str(root_path),
        "route_count": len(output_routes),
        "routes": output_routes,
        "tasks": tasks,
        "warnings": warnings,
    }
    if args.json:
        print(json.dumps(trace, ensure_ascii=False, indent=2))
        return 0
    print(f"CTX Trace {trace['trace_id']} lane={trace['lane_id']} root={args.route_id}")
    for route in output_routes:
        print(
            f"- {route['route_id']} [{route['status']}] lane={route.get('lane_id')} "
            f"{route['origin']} -> {route['target']} {route['title']}"
        )
        if route.get("reply"):
            print(f"  reply: {route['reply'].get('status')} by {route['reply'].get('executed_by')}")
        if route.get("inclusion_reason"):
            print(f"  included_by: {route.get('inclusion_reason')}")
        if route.get("verification"):
            print(f"  verification: {route['verification'].get('verdict')}")
    if warnings:
        print("Warnings")
        for warning in warnings:
            print(f"- {warning.get('kind')}: {warning.get('route_id')} reply_to={warning.get('reply_to')}")
    if tasks:
        print("Tasks")
        for task in tasks:
            print(f"- {task.get('task_id') or task.get('path')} [{task.get('status')}] {task.get('summary') or ''}")
    return 0


def iter_route_record_paths() -> list[Path]:
    ensure_dirs()
    out: list[Path] = []
    for directory in set(STATUS_DIRS.values()):
        out.extend(sorted(directory.glob("*.json")))
    return sorted(out)


def issue(
    severity: str,
    kind: str,
    summary: str,
    route_id: str | None = None,
    path: str | None = None,
    scope: str = "current",
    **details: object,
) -> dict:
    payload = {
        "severity": severity,
        "kind": kind,
        "scope": scope,
        "summary": summary,
    }
    if route_id:
        payload["route_id"] = route_id
    if path:
        payload["path"] = path
    for key, value in details.items():
        if value is not None:
            payload[key] = value
    return payload


def route_status_path_issue(path: Path, route: dict) -> dict | None:
    status = route.get("status")
    expected = STATUS_DIRS.get(str(status))
    if not expected:
        return issue("critical", "unsupported_status", f"unsupported route status: {status}", route.get("route_id"), str(path))
    if path.parent != expected:
        return issue(
            "warn",
            "status_path_mismatch",
            f"route status {status} is stored under {path.parent}",
            route.get("route_id"),
            str(path),
            expected_path=str(expected / path.name),
        )
    return None


def route_parent_trace_issue(route: dict, routes_by_id: dict[str, dict]) -> dict | None:
    reply_to = route.get("reply_to")
    if not isinstance(reply_to, str) or not reply_to:
        return None
    parent = routes_by_id.get(reply_to)
    if not parent:
        return issue("warn", "missing_reply_parent", "route reply_to parent is missing", route.get("route_id"), reply_to=reply_to)
    route_trace = route.get("trace_id") or route.get("route_id")
    parent_trace = parent.get("trace_id") or parent.get("route_id")
    if route_trace != parent_trace:
        scope = "history" if route.get("verification") and route.get("status") in TERMINAL_STATUSES else "current"
        return issue(
            "info" if scope == "history" else "warn",
            "cross_trace_reply_to",
            "route reply_to points across trace IDs",
            route.get("route_id"),
            scope=scope,
            reply_to=reply_to,
            route_trace_id=route_trace,
            parent_trace_id=parent_trace,
        )
    return None


def route_lifecycle_issue(
    route: dict,
    reference: dt.datetime,
    args: argparse.Namespace,
    claim_instance_required_after: dt.datetime | None = None,
) -> list[dict]:
    rid = route.get("route_id")
    status = route.get("status")
    issues = []
    created_age = age_seconds(route.get("created_at"), reference)
    updated_age = age_seconds(route.get("updated_at"), reference)
    if status == "queued" and created_age is not None and created_age > args.queued_warn_seconds:
        issues.append(issue("warn", "stale_queued_route", "queued route has not been claimed", rid, age_seconds=created_age))
    if status in ACTIVE_STATUSES:
        lease = route.get("lease") if isinstance(route.get("lease"), dict) else {}
        if not lease:
            issues.append(issue("warn", "active_route_missing_lease", "active route has no claim lease", rid))
        else:
            expires_at = parse_time(lease.get("expires_at"))
            if not expires_at:
                issues.append(issue("warn", "lease_missing_expiry", "active route lease has no valid expires_at", rid))
            elif expires_at < reference:
                issues.append(issue(
                    "critical",
                    "expired_active_lease",
                    "active route claim lease has expired",
                    rid,
                    expired_seconds=int((reference - expires_at).total_seconds()),
                    claimed_by=lease.get("claimed_by"),
                ))
            claimed_at = parse_time(lease.get("claimed_at"))
            if (
                claim_instance_required_after
                and claimed_at
                and claimed_at >= claim_instance_required_after
                and not lease.get("claim_instance_id")
            ):
                issues.append(issue(
                    "warn",
                    "missing_claim_instance_id",
                    "route claim is missing claimant instance_id after the required rollout time",
                    rid,
                    claimed_at=lease.get("claimed_at"),
                    claimed_by=lease.get("claimed_by"),
                    required_after=claim_instance_required_after.isoformat().replace("+00:00", "Z"),
                ))
    elif status in TERMINAL_STATUSES:
        lease = route.get("lease") if isinstance(route.get("lease"), dict) else {}
        claimed_at = parse_time(lease.get("claimed_at")) if lease else None
        if (
            claim_instance_required_after
            and claimed_at
            and claimed_at >= claim_instance_required_after
            and not lease.get("claim_instance_id")
        ):
            scope = "history" if route.get("verification") else "current"
            issues.append(issue(
                "info" if scope == "history" else "warn",
                "missing_claim_instance_id",
                "route claim is missing claimant instance_id after the required rollout time",
                rid,
                scope=scope,
                claimed_at=lease.get("claimed_at"),
                claimed_by=lease.get("claimed_by"),
                required_after=claim_instance_required_after.isoformat().replace("+00:00", "Z"),
            ))
    if status in UNVERIFIED_TERMINAL_STATUSES and not route.get("verification"):
        if updated_age is None or updated_age > args.unverified_warn_seconds:
            issues.append(issue("critical", "unverified_terminal_route", "terminal route has no origin-side verification", rid, age_seconds=updated_age))
    if status == "verified" and not route.get("verification"):
        issues.append(issue("critical", "verified_without_verification", "route status is verified but verification object is missing", rid))
    if status == "verified" and route.get("verification"):
        verification = route.get("verification") if isinstance(route.get("verification"), dict) else {}
        reply = route.get("reply") if isinstance(route.get("reply"), dict) else {}
        if verification.get("verdict") != "accepted":
            issues.append(issue("critical", "verified_without_accepted_verdict", "route status is verified without accepted verification verdict", rid))
        if reply.get("status") != "replied":
            issues.append(issue("critical", "verified_without_successful_reply", "route status is verified without a successful reply", rid))
    if status == "rejected":
        verification = route.get("verification") if isinstance(route.get("verification"), dict) else {}
        if verification.get("verdict") != "rejected":
            issues.append(issue("critical", "rejected_without_rejected_verdict", "route status is rejected without rejected verification verdict", rid))
    if not route.get("trace_id"):
        issues.append(issue("info", "legacy_missing_trace_id", "legacy route has no persisted trace_id", rid))
    return issues


def route_task_link_issues(route: dict) -> list[dict]:
    audit_profile, audit_issues = route_audit_context(route)
    return audit_issues + route_task_link_issues_with_profile(route, audit_profile)


def route_task_link_issues_with_profile(route: dict, audit_profile: dict) -> list[dict]:
    rid = route.get("route_id")
    reply = route.get("reply") if isinstance(route.get("reply"), dict) else {}
    if not reply:
        return []
    issues = []
    links = route_task_links(route, audit_profile)
    result_link_kind = str(audit_profile.get("result_link_kind") or "strict")
    expects_thread_id = bool(audit_profile.get("expects_thread_id"))
    ephemeral_session = bool(audit_profile.get("ephemeral_session"))
    observed_shape = route_reply_shape_kind(route)
    if result_link_kind != "strict":
        expected_links = [
            link for link in links
            if link.get("kind") == result_link_kind
            or route_reply_has_evidence_kind(route, result_link_kind)
            or observed_shape == result_link_kind
        ]
        if not expected_links and observed_shape != result_link_kind and not route_reply_has_evidence_kind(route, result_link_kind):
            issues.append(issue(
                "warn",
                "missing_expected_result_link_kind",
                "reply shape does not expose the expected result_link_kind marker",
                rid,
                expected=result_link_kind,
                observed=observed_shape,
            ))
        for link in expected_links:
            if link.get("path") and link.get("exists") is False:
                issues.append(issue(
                    "warn",
                    "missing_expected_result_artifact",
                    "expected result artifact is missing",
                    rid,
                    path=str(link.get("path")),
                    expected=result_link_kind,
                ))
            thread_id_field = str(audit_profile.get("thread_id_output_field") or "thread_id")
            thread_id = link.get(thread_id_field) or link.get("thread_id") or link.get("session_id")
            if expects_thread_id and link.get("read") and not thread_id:
                link_status = link.get("status") or link.get("ctx_status")
                scope = "history" if route.get("verification") and link_status != "success" else "current"
                issues.append(issue(
                    "info" if scope == "history" or ephemeral_session else "warn",
                    "missing_expected_thread_id",
                    "result artifact has no declared thread/session id mapping",
                    rid,
                    scope=scope,
                    task_id=str(link.get("task_id")),
                    task_status=link_status,
                    expected=result_link_kind,
                ))
    if expects_thread_id:
        visibility = {link.get("session_visibility") for link in links if link.get("session_visibility")}
        thread_id_field = str(audit_profile.get("thread_id_output_field") or "thread_id")
        has_session = any(link.get(thread_id_field) or link.get("thread_id") or link.get("session_id") for link in links)
        if "persisted" in visibility and not has_session:
            issues.append(issue(
                "info" if ephemeral_session else "warn",
                "missing_expected_thread_id",
                "reply is missing the expected session/thread id mapping",
                rid,
                expected=result_link_kind,
            ))
        elif "ephemeral" in visibility:
            issues.append(issue(
                "info",
                "ephemeral_session_without_mapping",
                "executor declared an ephemeral session; no persisted session mapping is expected",
                rid,
                expected=result_link_kind,
            ))
    return issues


def device_issues(devices: list[dict], reference: dt.datetime, stale_seconds: int) -> list[dict]:
    issues = []
    for profile in devices:
        device_id = profile.get("device_id")
        last_age = age_seconds(profile.get("last_seen"), reference)
        if last_age is None:
            issues.append(issue("warn", "device_missing_last_seen", "device profile has no valid last_seen", str(device_id)))
        elif last_age > stale_seconds:
            issues.append(issue("warn", "stale_device_heartbeat", "device heartbeat is stale", str(device_id), age_seconds=last_age, health=profile.get("health")))
        if profile.get("health") not in ("up", "ok", None):
            issues.append(issue("warn", "device_health_not_up", "device health is not up", str(device_id), health=profile.get("health")))
    return issues


def probe_tcp_transport(probe: dict, timeout: float) -> dict:
    result = {
        "name": probe["name"],
        "kind": "tcp",
        "host": probe["host"],
        "port": probe["port"],
        "checked_at": now(),
        "ok": False,
    }
    try:
        with socket.create_connection((probe["host"], int(probe["port"])), timeout=timeout):
            result["ok"] = True
    except OSError as exc:
        result["error"] = f"{exc.__class__.__name__}: {exc}"
    return result


def transport_probe_issues(probes: list[dict]) -> list[dict]:
    issues = []
    for probe in probes:
        if probe.get("ok"):
            continue
        issues.append(issue(
            "warn",
            "transport_probe_down",
            "transport probe failed",
            str(probe.get("name")),
            target=f"{probe.get('host')}:{probe.get('port')}",
            error=probe.get("error"),
        ))
    return issues


def duplicate_route_issues(paths: list[Path]) -> list[dict]:
    by_id: dict[str, list[str]] = {}
    for path in paths:
        by_id.setdefault(path.stem, []).append(str(path))
    return [
        issue("critical", "duplicate_route_record", "route id exists in multiple state files", rid, paths=items)
        for rid, items in sorted(by_id.items())
        if len(items) > 1
    ]


def load_devices() -> list[dict]:
    ensure_dirs()
    out = []
    for path in sorted(DEVICES.glob("*.json")):
        try:
            profile = json.loads(path.read_text(encoding="utf-8"))
            profile["_path"] = str(path)
            out.append(profile)
        except Exception as exc:
            out.append({"device_id": path.stem, "error": str(exc), "_path": str(path)})
    return out


def load_agent_instances() -> list[dict]:
    ensure_dirs()
    out = []
    for path in sorted(AGENT_INSTANCES.glob("*.json")):
        try:
            instance = json.loads(path.read_text(encoding="utf-8"))
            instance["_path"] = str(path)
            out.append(instance)
        except Exception as exc:
            out.append({"instance_id": path.stem, "error": str(exc), "_path": str(path)})
    return out


def load_route_call_metric_events() -> list[dict]:
    ensure_dirs()
    out = []
    for path in sorted(ROUTE_CALL_METRICS.glob("*.json")):
        try:
            event = json.loads(path.read_text(encoding="utf-8"))
            event["_path"] = str(path)
            out.append(event)
        except Exception as exc:
            out.append({"event_id": path.stem, "error": str(exc), "_path": str(path)})
    return out


def route_call_metric_events_by_instance(events: list[dict]) -> dict[str, list[dict]]:
    by_instance: dict[str, list[dict]] = {}
    for event in events:
        instance_id = event.get("instance_id")
        if not instance_id:
            continue
        by_instance.setdefault(str(instance_id), []).append(event)
    return by_instance


def should_load_route_call_metric_events(args: argparse.Namespace) -> bool:
    return bool(
        getattr(args, "include_metric_events", False)
        or (
            getattr(args, "agent_latency_warn_ms", 0) > 0
            and bool(getattr(args, "agent_latency_observed_after", ""))
        )
    )


def metric_event_latency_view(
    events: list[dict],
    observed_after: dt.datetime | None = None,
    observed_before: dt.datetime | None = None,
) -> dict:
    values: list[int] = []
    latest_observed_at = None
    max_event = None
    max_elapsed_ms = None
    for item in events:
        if not isinstance(item, dict):
            continue
        observed_at = parse_time(item.get("observed_at"))
        if observed_after and (not observed_at or observed_at < observed_after):
            continue
        if observed_before and (not observed_at or observed_at > observed_before):
            continue
        elapsed_ms = item.get("elapsed_ms")
        if not isinstance(elapsed_ms, int):
            continue
        values.append(elapsed_ms)
        if max_elapsed_ms is None or elapsed_ms > max_elapsed_ms:
            max_elapsed_ms = elapsed_ms
            max_event = item
        if observed_at and (latest_observed_at is None or observed_at > latest_observed_at):
            latest_observed_at = observed_at
    if not values:
        return {
            "max_elapsed_ms": None,
            "sample_count": 0,
            "scope": "metric_ledger_no_samples",
            "observed_after": observed_after.isoformat().replace("+00:00", "Z") if observed_after else None,
            "observed_before": observed_before.isoformat().replace("+00:00", "Z") if observed_before else None,
            "latest_observed_at": None,
        }
    max_event_view = {
        "operation": max_event.get("operation") if isinstance(max_event, dict) else None,
        "elapsed_ms": max_elapsed_ms,
        "attempts": max_event.get("attempts") if isinstance(max_event, dict) else None,
        "ok": max_event.get("ok") if isinstance(max_event, dict) else None,
        "observed_at": max_event.get("observed_at") if isinstance(max_event, dict) else None,
        "event_id": max_event.get("event_id") if isinstance(max_event, dict) else None,
        "path": max_event.get("_path") if isinstance(max_event, dict) else None,
    }
    return {
        "max_elapsed_ms": max_elapsed_ms,
        "max_event": {key: value for key, value in max_event_view.items() if value is not None},
        "sample_count": len(values),
        "scope": "metric_ledger_since" if observed_after else "metric_ledger",
        "observed_after": observed_after.isoformat().replace("+00:00", "Z") if observed_after else None,
        "observed_before": observed_before.isoformat().replace("+00:00", "Z") if observed_before else None,
        "latest_observed_at": latest_observed_at.isoformat().replace("+00:00", "Z") if latest_observed_at else None,
    }


def metrics_latency_view(
    metrics: dict,
    observed_after: dt.datetime | None = None,
    observed_before: dt.datetime | None = None,
    *,
    fallback_to_lifetime: bool = True,
    ledger_events: list[dict] | None = None,
) -> dict:
    if ledger_events is not None:
        ledger_view = metric_event_latency_view(ledger_events, observed_after, observed_before)
        if ledger_view.get("sample_count"):
            return ledger_view
    recent = metrics.get("recent") if isinstance(metrics.get("recent"), list) else []
    values: list[int] = []
    latest_observed_at = None
    max_event = None
    max_elapsed_ms = None
    for item in recent:
        if not isinstance(item, dict):
            continue
        observed_at = parse_time(item.get("observed_at"))
        if observed_after and (not observed_at or observed_at < observed_after):
            continue
        if observed_before and (not observed_at or observed_at > observed_before):
            continue
        elapsed_ms = item.get("elapsed_ms")
        if not isinstance(elapsed_ms, int):
            continue
        values.append(elapsed_ms)
        if max_elapsed_ms is None or elapsed_ms > max_elapsed_ms:
            max_elapsed_ms = elapsed_ms
            max_event = item
        if observed_at and (latest_observed_at is None or observed_at > latest_observed_at):
            latest_observed_at = observed_at
    if values:
        max_event_view = {
            "operation": max_event.get("operation") if isinstance(max_event, dict) else None,
            "elapsed_ms": max_elapsed_ms,
            "attempts": max_event.get("attempts") if isinstance(max_event, dict) else None,
            "ok": max_event.get("ok") if isinstance(max_event, dict) else None,
            "observed_at": max_event.get("observed_at") if isinstance(max_event, dict) else None,
        }
        return {
            "max_elapsed_ms": max_elapsed_ms,
            "max_event": {key: value for key, value in max_event_view.items() if value is not None},
            "sample_count": len(values),
            "scope": "recent_since" if observed_after else "recent",
            "observed_after": observed_after.isoformat().replace("+00:00", "Z") if observed_after else None,
            "observed_before": observed_before.isoformat().replace("+00:00", "Z") if observed_before else None,
            "latest_observed_at": latest_observed_at.isoformat().replace("+00:00", "Z") if latest_observed_at else None,
        }
    if fallback_to_lifetime:
        return {
            "max_elapsed_ms": metrics.get("max_elapsed_ms"),
            "sample_count": None,
            "scope": "instance_lifetime",
            "observed_after": observed_after.isoformat().replace("+00:00", "Z") if observed_after else None,
            "observed_before": observed_before.isoformat().replace("+00:00", "Z") if observed_before else None,
            "latest_observed_at": None,
        }
    return {
        "max_elapsed_ms": None,
        "sample_count": 0,
        "scope": "no_recent_samples",
        "observed_after": observed_after.isoformat().replace("+00:00", "Z") if observed_after else None,
        "observed_before": observed_before.isoformat().replace("+00:00", "Z") if observed_before else None,
        "latest_observed_at": None,
    }


def superseding_agent_instance(instance: dict, instances: list[dict]) -> dict | None:
    device_id = instance.get("device_id")
    agent_id = instance.get("agent_id")
    instance_id = instance.get("instance_id")
    last_seen_at = parse_time(instance.get("last_seen"))
    if not device_id or not agent_id or not instance_id or not last_seen_at:
        return None
    best = None
    best_started_at = None
    for other in instances:
        if other is instance:
            continue
        if other.get("device_id") != device_id or other.get("agent_id") != agent_id:
            continue
        if other.get("instance_id") == instance_id:
            continue
        if (other.get("state") or "active") in {"profile", "stopped"}:
            continue
        other_started_at = parse_time(other.get("started_at"))
        other_last_seen_at = parse_time(other.get("last_seen"))
        if not other_started_at or not other_last_seen_at:
            continue
        if other_started_at <= last_seen_at:
            continue
        if other_last_seen_at < other_started_at:
            continue
        if best_started_at is None or other_started_at > best_started_at:
            best = other
            best_started_at = other_started_at
    return best


def agent_instance_issues(
    instances: list[dict],
    reference: dt.datetime,
    stale_seconds: int,
    latency_warn_ms: int,
    code_required_after: dt.datetime | None = None,
    latency_observed_after: dt.datetime | None = None,
    metric_events_by_instance: dict[str, list[dict]] | None = None,
) -> list[dict]:
    issues = []
    active_by_agent: dict[tuple[object, object], list[dict]] = {}
    for instance in instances:
        device_id = instance.get("device_id")
        agent_id = instance.get("agent_id")
        instance_id = instance.get("instance_id")
        state = instance.get("state") or "active"
        metrics = instance.get("metrics") if isinstance(instance.get("metrics"), dict) else {}
        agent_code = instance.get("agent_code") if isinstance(instance.get("agent_code"), dict) else {}
        last_age = age_seconds(instance.get("last_seen"), reference)
        if not device_id or not agent_id or not instance_id:
            issues.append(issue(
                "warn",
                "agent_instance_identity_incomplete",
                "agent instance heartbeat is missing identity fields",
                str(device_id or instance_id or "unknown"),
                path=instance.get("_path"),
            ))
            continue
        if last_age is None:
            issues.append(issue(
                "warn",
                "agent_instance_missing_last_seen",
                "agent instance heartbeat has no valid last_seen",
                str(device_id),
                agent_id=agent_id,
                instance_id=instance_id,
            ))
            continue
        last_seen_at = parse_time(instance.get("last_seen"))
        superseded_by = None
        if state not in {"profile", "stopped"}:
            superseded_by = superseding_agent_instance(instance, instances)
        if superseded_by:
            issues.append(issue(
                "info",
                "superseded_agent_instance",
                "agent heartbeat was superseded by a newer active instance before it could retire",
                str(device_id),
                scope="history",
                agent_id=agent_id,
                instance_id=instance_id,
                last_seen=instance.get("last_seen"),
                superseded_by=superseded_by.get("instance_id"),
                superseding_started_at=superseded_by.get("started_at"),
            ))
            continue
        if (
            code_required_after
            and last_seen_at
            and last_seen_at >= code_required_after
            and not agent_code.get("sha256")
        ):
            historical_state = state in {"profile", "stopped"}
            issues.append(issue(
                "info" if historical_state else "warn",
                "missing_agent_code_fingerprint",
                "agent heartbeat is missing code fingerprint after the required rollout time",
                str(device_id),
                scope="history" if historical_state else "current",
                agent_id=agent_id,
                instance_id=instance_id,
                state=state,
                last_seen=instance.get("last_seen"),
                required_after=code_required_after.isoformat().replace("+00:00", "Z"),
            ))
        sha256 = agent_code.get("sha256")
        if sha256 and not re.fullmatch(r"[0-9a-f]{64}", str(sha256)):
            issues.append(issue(
                "warn",
                "invalid_agent_code_fingerprint",
                "agent heartbeat code fingerprint is not a lowercase sha256 hex digest",
                str(device_id),
                agent_id=agent_id,
                instance_id=instance_id,
                state=state,
                sha256=sha256,
            ))
        loaded_sha256 = agent_code.get("loaded_sha256")
        if loaded_sha256 and not re.fullmatch(r"[0-9a-f]{64}", str(loaded_sha256)):
            issues.append(issue(
                "warn",
                "invalid_loaded_agent_code_fingerprint",
                "agent heartbeat loaded code fingerprint is not a lowercase sha256 hex digest",
                str(device_id),
                agent_id=agent_id,
                instance_id=instance_id,
                state=state,
                loaded_sha256=loaded_sha256,
            ))
        historical_state = state in {"profile", "stopped"}
        started_at = parse_time(instance.get("started_at"))
        tool_mtime = parse_time(agent_code.get("mtime"))
        if started_at and tool_mtime and tool_mtime > started_at:
            issues.append(issue(
                "info" if historical_state else "warn",
                "agent_process_predates_tool_code",
                "agent process started before the current tool mtime; running code may predate the deployed file",
                str(device_id),
                scope="history" if historical_state else "current",
                agent_id=agent_id,
                instance_id=instance_id,
                state=state,
                started_at=instance.get("started_at"),
                tool_mtime=agent_code.get("mtime"),
                tool_path=agent_code.get("tool_path"),
            ))
        if sha256 and loaded_sha256 and sha256 != loaded_sha256:
            issues.append(issue(
                "info" if historical_state else "warn",
                "agent_loaded_code_differs_from_tool_file",
                "agent startup-loaded code fingerprint differs from the current tool file fingerprint",
                str(device_id),
                scope="history" if historical_state else "current",
                agent_id=agent_id,
                instance_id=instance_id,
                state=state,
                tool_sha256=sha256,
                loaded_sha256=loaded_sha256,
                tool_path=agent_code.get("tool_path"),
            ))
        latency_view = metrics_latency_view(
            metrics,
            latency_observed_after,
            None,
            fallback_to_lifetime=latency_observed_after is None,
            ledger_events=(metric_events_by_instance or {}).get(str(instance_id)),
        )
        max_elapsed_ms = latency_view.get("max_elapsed_ms")
        if latency_warn_ms > 0 and isinstance(max_elapsed_ms, int) and max_elapsed_ms > latency_warn_ms:
            issues.append(issue(
                "warn",
                "agent_route_call_latency_high",
                "agent route-ledger call latency exceeded threshold",
                str(device_id),
                agent_id=agent_id,
                instance_id=instance_id,
                state=state,
                max_elapsed_ms=max_elapsed_ms,
                threshold_ms=latency_warn_ms,
                call_count=metrics.get("call_count"),
                failed_call_count=metrics.get("failed_call_count"),
                latency_scope=latency_view.get("scope"),
                observed_after=latency_view.get("observed_after"),
                sample_count=latency_view.get("sample_count"),
                latest_observed_at=latency_view.get("latest_observed_at"),
                max_operation=(latency_view.get("max_event") or {}).get("operation"),
                max_attempts=(latency_view.get("max_event") or {}).get("attempts"),
                max_observed_at=(latency_view.get("max_event") or {}).get("observed_at"),
            ))
        if state in {"profile", "stopped"}:
            continue
        if last_age > stale_seconds:
            issues.append(issue(
                "warn",
                "stale_agent_instance",
                "agent instance heartbeat is stale",
                str(device_id),
                agent_id=agent_id,
                instance_id=instance_id,
                age_seconds=last_age,
            ))
            continue
        active_by_agent.setdefault((device_id, agent_id), []).append(instance)
    for (device_id, agent_id), active in sorted(active_by_agent.items(), key=lambda item: str(item[0])):
        if len(active) <= 1:
            continue
        issues.append(issue(
            "warn",
            "duplicate_active_agent_instances",
            "multiple fresh claimant instances report the same device and agent",
            str(device_id),
            agent_id=agent_id,
            active_instance_count=len(active),
            instance_ids=[item.get("instance_id") for item in active],
        ))
    return issues


def doctor_report(args: argparse.Namespace, include_circuit_breaker: bool = True) -> dict:
    reference = utc_now()
    policy = load_policy()
    claim_instance_required_after = None
    if getattr(args, "claim_instance_required_after", ""):
        claim_instance_required_after = parse_time(args.claim_instance_required_after)
        if not claim_instance_required_after:
            raise SystemExit("--claim-instance-required-after must be an ISO UTC timestamp")
    agent_code_required_after = None
    if getattr(args, "agent_code_required_after", ""):
        agent_code_required_after = parse_time(args.agent_code_required_after)
        if not agent_code_required_after:
            raise SystemExit("--agent-code-required-after must be an ISO UTC timestamp")
    agent_latency_observed_after = None
    if getattr(args, "agent_latency_observed_after", ""):
        agent_latency_observed_after = parse_time(args.agent_latency_observed_after)
        if not agent_latency_observed_after:
            raise SystemExit("--agent-latency-observed-after must be an ISO UTC timestamp")
    paths = iter_route_record_paths()
    routes = iter_routes()
    devices = load_devices()
    agent_instances = load_agent_instances()
    metric_events_loaded = should_load_route_call_metric_events(args)
    metric_events = load_route_call_metric_events() if metric_events_loaded else []
    metric_events_by_instance = route_call_metric_events_by_instance(metric_events)
    transport_probes = [
        probe_tcp_transport(probe, args.transport_probe_timeout)
        for probe in (args.transport_probe or [])
    ]
    routes_by_id = {route.get("route_id"): route for _path, route in routes if route.get("route_id")}
    device_ids = {profile.get("device_id") for profile in devices}
    all_issues: list[dict] = []
    all_issues.extend(duplicate_route_issues(paths))

    task_links = []
    for path, raw_route in routes:
        route = dict(raw_route)
        rid = route.get("route_id") or path.stem
        if route.get("status") == "parse_error":
            all_issues.append(issue("critical", "parse_error", "route JSON could not be parsed", str(rid), str(path), error=route.get("error")))
            continue
        status_issue = route_status_path_issue(path, route)
        if status_issue:
            all_issues.append(status_issue)
        if route.get("target_site") not in device_ids and str(route.get("target_site")) not in DEVICE_ALIASES:
            all_issues.append(issue("warn", "unknown_target_device", "route target_site has no device profile", str(rid), target_site=route.get("target_site")))
        if SECRET_VALUE_RE.search(json.dumps(route, ensure_ascii=False, sort_keys=True)):
            all_issues.append(issue("critical", "secret_shaped_route_content", "route record contains secret-shaped content", str(rid), str(path)))
        try:
            validate_route_schema(normalize_route(route))
        except SystemExit as exc:
            all_issues.append(issue("critical", "route_schema_invalid", str(exc), str(rid), str(path)))
        parent_issue = route_parent_trace_issue(route, routes_by_id)
        if parent_issue:
            all_issues.append(parent_issue)
        all_issues.extend(route_lifecycle_issue(route, reference, args, claim_instance_required_after))
        audit_profile, audit_issues = route_audit_context(route)
        all_issues.extend(audit_issues)
        all_issues.extend(route_task_link_issues_with_profile(route, audit_profile))
        for link in route_task_links(route, audit_profile):
            link = dict(link)
            link["route_id"] = rid
            task_links.append(link)

    all_issues.extend(device_issues(devices, reference, args.device_stale_seconds))
    all_issues.extend(agent_instance_issues(
        agent_instances,
        reference,
        args.agent_stale_seconds,
        args.agent_latency_warn_ms,
        agent_code_required_after,
        agent_latency_observed_after,
        metric_events_by_instance,
    ))
    all_issues.extend(transport_probe_issues(transport_probes))
    circuit_breaker = circuit_breaker_public_state()
    if include_circuit_breaker and circuit_breaker.get("state") == "open":
        severity = circuit_breaker.get("severity") or "warn"
        all_issues.append(issue(
            severity,
            "circuit_breaker_open",
            circuit_breaker.get("reason") or "circuit breaker is open",
            "ctx-control-plane",
            scope="current",
            opened_at=circuit_breaker.get("opened_at"),
            opened_by=circuit_breaker.get("opened_by"),
        ))
    counts = Counter(str(route.get("status")) for _path, route in routes)
    severities = Counter(item["severity"] for item in all_issues)
    current_severities = Counter(item["severity"] for item in all_issues if item.get("scope") == "current")
    active_routes = []
    for _path, route in routes:
        status = route.get("status")
        needs_attention = status in ("queued", "claimed", "running", "replied", "needs_approval") or (
            status in ("failed", "blocked") and not route.get("verification")
        )
        if not needs_attention:
            continue
        active_routes.append({
            "route_id": route.get("route_id"),
            "trace_id": route.get("trace_id"),
            "lane_id": route_lane_id(route),
            "work_chat_id": route.get("work_chat_id"),
            "context_id": route.get("context_id"),
            "status": status,
            "target": f"{route.get('target_site')}:{route.get('target_agent')}",
            "title": route.get("title_auto") or route.get("title_original"),
            "lease": route.get("lease"),
        })
    health = "critical" if current_severities.get("critical") else "warn" if current_severities.get("warn") else "ok"
    return {
        "generated_at": now(),
        "health": health,
        "route_count": len(routes),
        "status_counts": dict(sorted(counts.items())),
        "device_count": len(devices),
        "metric_event_count": len(metric_events),
        "metric_events_loaded": metric_events_loaded,
        "policy": {
            "claim_instance_required": bool(policy.get("claim_instance_required")),
            "claim_agent_code_current_required": claim_agent_code_current_required(),
            "max_active_routes_total": max_active_routes_total(),
            "max_active_routes_per_target": max_active_routes_per_target(),
            "max_active_routes_per_lane": max_active_routes_per_lane(),
            "max_pending_routes_per_target": max_pending_routes_per_target(),
            "max_pending_routes_per_lane": max_pending_routes_per_lane(),
            "circuit_breaker_enabled": circuit_breaker_enabled(),
            "circuit_breaker_open_on_doctor_critical": circuit_breaker_open_on_doctor_critical(),
            "circuit_breaker_open_on_doctor_warn": circuit_breaker_open_on_doctor_warn(),
            "circuit_breaker_max_active_routes": circuit_breaker_max_active_routes(),
            "circuit_breaker_max_pending_routes": circuit_breaker_max_pending_routes(),
            "updated_at": policy.get("updated_at"),
            "updated_by": policy.get("updated_by"),
        },
        "circuit_breaker": circuit_breaker,
        "latency_policy": {
            "agent_latency_warn_ms": args.agent_latency_warn_ms,
            "agent_latency_observed_after": (
                agent_latency_observed_after.isoformat().replace("+00:00", "Z")
                if agent_latency_observed_after else None
            ),
        },
        "devices": [
            {
                "device_id": profile.get("device_id"),
                "health": profile.get("health"),
                "last_seen": profile.get("last_seen"),
                "agents": profile.get("agents") or [],
            }
            for profile in devices
        ],
        "agent_instance_count": len(agent_instances),
        "agent_instances": [
            {
                "device_id": instance.get("device_id"),
                "agent_id": instance.get("agent_id"),
                "instance_id": instance.get("instance_id"),
                "pid": instance.get("pid"),
                "hostname": instance.get("hostname"),
                "started_at": instance.get("started_at"),
                "first_seen": instance.get("first_seen"),
                "last_seen": instance.get("last_seen"),
                "stopped_at": instance.get("stopped_at"),
                "role": instance.get("role"),
                "state": instance.get("state") or "active",
                "agent_code": instance.get("agent_code") if isinstance(instance.get("agent_code"), dict) else None,
                "metrics": instance.get("metrics") if isinstance(instance.get("metrics"), dict) else None,
            }
            for instance in agent_instances
        ],
        "active_routes": active_routes,
        "transport_probes": transport_probes,
        "issue_count": len(all_issues),
        "issue_counts": dict(sorted(severities.items())),
        "current_issue_counts": dict(sorted(current_severities.items())),
        "issues": all_issues,
        "task_links": task_links,
    }


def print_doctor_text(report: dict, task_limit: int = 20) -> None:
    print(f"CTX Route Doctor [{report['health']}] generated_at={report['generated_at']}")
    print(
        f"routes={report['route_count']} devices={report['device_count']} "
        f"metric_events={report.get('metric_event_count', 0)} issues={report['issue_count']}"
    )
    policy = report.get("policy") or {}
    print(
        f"Policy claim_instance_required={policy.get('claim_instance_required')} "
        f"claim_agent_code_current_required={policy.get('claim_agent_code_current_required')} "
        f"max_active_total={policy.get('max_active_routes_total')} "
        f"max_active_per_target={policy.get('max_active_routes_per_target')} "
        f"max_active_per_lane={policy.get('max_active_routes_per_lane')} "
        f"max_pending_per_target={policy.get('max_pending_routes_per_target')} "
        f"max_pending_per_lane={policy.get('max_pending_routes_per_lane')} "
        f"circuit_breaker={policy.get('circuit_breaker_enabled')}"
    )
    circuit = report.get("circuit_breaker") or {}
    print(
        f"Circuit Breaker state={circuit.get('state')} "
        f"severity={circuit.get('severity') or 'none'} "
        f"max_active={policy.get('circuit_breaker_max_active_routes')} "
        f"max_pending={policy.get('circuit_breaker_max_pending_routes')}"
    )
    print("Status")
    for status, count in report.get("status_counts", {}).items():
        print(f"- {status}: {count}")
    print("Devices")
    for device in report.get("devices", []):
        print(f"- {device.get('device_id')} health={device.get('health')} last_seen={device.get('last_seen')} agents={','.join(device.get('agents') or [])}")
    instances = report.get("agent_instances") or []
    if instances:
        print("Agent Instances")
        for instance in instances:
            print(
                f"- {instance.get('device_id')} {instance.get('agent_id')} "
                f"instance={instance.get('instance_id')} pid={instance.get('pid')} "
                f"state={instance.get('state') or 'active'} last_seen={instance.get('last_seen')}"
            )
    probes = report.get("transport_probes") or []
    if probes:
        print("Transport Probes")
        for probe in probes:
            status = "ok" if probe.get("ok") else "down"
            target = f"{probe.get('host')}:{probe.get('port')}"
            error = f" error={probe.get('error')}" if probe.get("error") else ""
            print(f"- {probe.get('name')} {probe.get('kind')} {target} {status}{error}")
    active = report.get("active_routes") or []
    if active:
        print("Active/Pending Routes")
        for route in active[:20]:
            print(
                f"- {route.get('route_id')} [{route.get('status')}] "
                f"lane={route.get('lane_id')} {route.get('target')} {route.get('title')}"
            )
    issues = report.get("issues") or []
    if issues:
        print("Issues")
        for item in issues[:50]:
            rid = f" {item.get('route_id')}" if item.get("route_id") else ""
            scope = f"[{item.get('scope')}]" if item.get("scope") else ""
            print(f"- {item.get('severity').upper()} {scope} {item.get('kind')}{rid}: {item.get('summary')}")
    links = report.get("task_links") or []
    if links:
        print("Task Links")
        for link in links[:task_limit]:
            task_id = link.get("task_id") or link.get("output_path") or link.get("path")
            thread = link.get("thread_id") or link.get("codex_thread_id") or link.get("session_id") or "unmapped"
            print(f"- {link.get('route_id')} -> {task_id} thread={thread} kind={link.get('kind')}")


def cmd_doctor(args: argparse.Namespace) -> int:
    report = doctor_report(args)
    if args.json:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    else:
        print_doctor_text(report, args.task_link_limit)
    if args.strict and report.get("health") == "critical":
        return 2
    return 0


def drill_subprocess(base: Path, *argv: str, input_obj: dict | None = None) -> subprocess.CompletedProcess:
    env = {**os.environ, "CTX_BASE": str(base)}
    payload = json.dumps(input_obj, ensure_ascii=False) if input_obj is not None else None
    return subprocess.run(
        [sys.executable, str(Path(__file__).resolve()), *argv],
        input=payload,
        text=True,
        capture_output=True,
        env=env,
    )


def drill_command(base: Path, *argv: str, input_obj: dict | None = None) -> dict:
    result = drill_subprocess(base, *argv, input_obj=input_obj)
    return {
        "args": list(argv),
        "returncode": result.returncode,
        "stdout": safe_text(result.stdout.strip(), 1600),
        "stderr": safe_text(result.stderr.strip(), 1600),
    }


def drill_json(base: Path, *argv: str, input_obj: dict | None = None) -> dict:
    result = drill_subprocess(base, *argv, input_obj=input_obj)
    if result.returncode != 0:
        raise RuntimeError(f"drill command failed: {' '.join(argv)}: {safe_text(result.stderr.strip(), 1600)}")
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError as exc:
        raise RuntimeError(f"drill command did not return JSON: {' '.join(argv)}") from exc


def drill_check(name: str, ok: bool, summary: str, **details: object) -> dict:
    payload = {
        "name": name,
        "ok": bool(ok),
        "summary": summary,
    }
    payload.update({key: value for key, value in details.items() if value is not None})
    return payload


def write_drill_json(path: Path, data: dict) -> None:
    reject_secret_shaped_values(data, str(path))
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def expire_drill_running_lease(base: Path, route_id: str) -> None:
    path = base / "routes" / "running" / f"{route_id}.json"
    route = json.loads(path.read_text(encoding="utf-8"))
    route["lease"]["expires_at"] = "2000-01-01T00:00:00Z"
    write_drill_json(path, route)


def reserve_closed_tcp_port() -> int:
    probe = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    try:
        probe.bind(("127.0.0.1", 0))
        return int(probe.getsockname()[1])
    finally:
        probe.close()


def run_route_drill(base: Path, transport_probe_timeout: float) -> dict:
    base.mkdir(parents=True, exist_ok=True)
    checks: list[dict] = []

    ling_profile = {
        "device_id": "lingxiaodian",
        "os": "linux",
        "agents": ["codex", "local-native"],
        "capabilities": ["ctx-route", "ctx-codex", "linux"],
        "transports": ["local-file-ledger"],
        "red_lines": ["no_secrets", "human_audit"],
        "health": "up",
    }
    hua_profile = {
        "device_id": "huaguoshan-macos",
        "os": "macos",
        "agents": ["local-native", "codex"],
        "capabilities": ["ctx-route", "mac-basic-status", "codex"],
        "transports": ["ssh-to-lingxiaodian", "frp-return-link"],
        "red_lines": ["no_unrestricted_remote_shell", "human_audit"],
        "health": "up",
    }
    drill_json(base, "device-upsert", "--profile-file", "-", input_obj=ling_profile)
    drill_json(base, "device-upsert", "--profile-file", "-", input_obj=hua_profile)
    drill_json(
        base,
        "agent-register",
        "--profile-file",
        "-",
        input_obj={
            "schema": AGENT_PROFILE_SCHEMA,
            "agent_key": "lingxiaodian/local-native-drill",
            "agent_id": "lingxiaodian:local-native",
            "device_id": "lingxiaodian",
            "engine": {"name": "drill", "version": "1.0.0", "model": "local"},
            "kind": "executor",
            "capabilities": ["os.linux", "runtime.shell", "ctx.smoke"],
            "constraints_supported": ["read_only_first", "no_secrets"],
            "transports": ["transport.local"],
            "audit_profile": default_audit_profile(),
            "secret_capabilities": [],
            "red_lines": ["metadata_first", "no_secret_values"],
        },
    )
    drill_json(
        base,
        "agent-register",
        "--profile-file",
        "-",
        input_obj={
            "schema": AGENT_PROFILE_SCHEMA,
            "agent_key": "lingxiaodian/codex-drill",
            "agent_id": "lingxiaodian:codex",
            "device_id": "lingxiaodian",
            "engine": {"name": "codex", "version": "1.0.0", "model": "gpt-test"},
            "kind": "executor",
            "capabilities": ["os.linux", "runtime.codex", "ctx.route"],
            "constraints_supported": ["read_only_first", "no_secrets"],
            "transports": ["transport.local"],
            "audit_profile": {
                "result_link_kind": "ctx-codex-result",
                "expects_thread_id": True,
                "ephemeral_session": False,
                "thread_field": "codex_thread",
                "thread_id_field": "id",
                "thread_model_field": "model",
                "thread_id_output_field": "codex_thread_id",
                "thread_model_output_field": "codex_thread_model",
            },
            "secret_capabilities": [],
            "red_lines": ["metadata_first", "no_secret_values"],
        },
    )
    drill_json(
        base,
        "agent-heartbeat",
        "--device-id",
        "lingxiaodian",
        "--agent-id",
        "lingxiaodian:codex",
        "--instance-id",
        "drill-ling-1",
        "--pid",
        "1001",
        "--hostname",
        "lingxiaodian",
        "--started-at",
        "2026-06-14T00:00:00Z",
        "--role",
        "drill",
    )
    drill_json(
        base,
        "agent-heartbeat",
        "--device-id",
        "lingxiaodian",
        "--agent-id",
        "lingxiaodian:codex",
        "--instance-id",
        "drill-ling-2",
        "--pid",
        "1002",
        "--hostname",
        "lingxiaodian",
        "--started-at",
        "2026-06-14T00:00:01Z",
        "--role",
        "drill",
    )
    instance_report = drill_json(base, "doctor", "--json", "--agent-stale-seconds", "999999")
    checks.append(drill_check(
        "duplicate_agent_instance_detected",
        "duplicate_active_agent_instances" in {item.get("kind") for item in instance_report.get("issues") or []},
        "Doctor detects multiple fresh claimant instances for the same device and agent.",
        agent_id="lingxiaodian:codex",
    ))
    duplicate_instance = agent_instance_path_under(base, "lingxiaodian", "lingxiaodian:codex", "drill-ling-2")
    if duplicate_instance.exists():
        duplicate_instance.unlink()
    devices = drill_json(base, "devices", "--json")
    checks.append(drill_check(
        "device_profiles",
        len(devices) == 2 and {item.get("device_id") for item in devices} == {"lingxiaodian", "huaguoshan-macos"},
        "Lingxiaodian and Huaguoshan device profiles are present in the isolated drill ledger.",
    ))

    drill_json(
        base,
        "create",
        "--route-id",
        "route_drill_happy",
        "--trace-id",
        "trace_drill_happy",
        "--target-site",
        "lingxiaodian",
        "--target-agent",
        "local-native",
        "--task-kind",
        "inspect",
        "--title-original",
        "Drill happy lifecycle",
    )
    happy_claim = drill_json(base, "claim", "route_drill_happy", "--device-id", "lingxiaodian", "--agent-id", "lingxiaodian:local-native")
    drill_json(
        base,
        "start",
        "route_drill_happy",
        "--agent-id",
        "lingxiaodian:local-native",
        "--lease-id",
        happy_claim.get("lease_id", ""),
    )
    drill_json(
        base,
        "reply",
        "route_drill_happy",
        "--reply-file",
        "-",
        "--agent-id",
        "lingxiaodian:local-native",
        "--lease-id",
        happy_claim.get("lease_id", ""),
        input_obj={
            "route_id": "route_drill_happy",
            "status": "replied",
            "executed_by": "lingxiaodian:local-native",
            "summary": "Drill lifecycle route completed.",
            "evidence": [{"kind": "synthetic-drill", "check": "lifecycle"}],
            "artifacts": [],
            "secret_events": [],
            "residual_risk": "Synthetic isolated ledger only.",
            "next_action": "origin verify",
        },
    )
    drill_json(base, "verify", "route_drill_happy", "--verdict", "accepted", "--summary", "lifecycle accepted")
    happy_route = drill_json(base, "show", "route_drill_happy")
    checks.append(drill_check(
        "route_lifecycle_happy_path",
        happy_route.get("status") == "verified" and len(happy_route.get("events") or []) == 5,
        "Route create -> claim -> start -> reply -> verify completed with auditable events.",
        route_id="route_drill_happy",
    ))

    drill_json(
        base,
        "create",
        "--route-id",
        "route_drill_expired",
        "--target-site",
        "lingxiaodian",
        "--target-agent",
        "codex",
        "--task-kind",
        "inspect",
        "--title-original",
        "Drill expired active lease",
    )
    expired_claim = drill_json(
        base,
        "claim",
        "route_drill_expired",
        "--device-id",
        "lingxiaodian",
        "--agent-id",
        "lingxiaodian:codex",
    )
    drill_json(
        base,
        "start",
        "route_drill_expired",
        "--agent-id",
        "lingxiaodian:codex",
        "--lease-id",
        expired_claim.get("lease_id", ""),
    )
    expire_drill_running_lease(base, "route_drill_expired")
    expired_report = drill_json(base, "doctor", "--json")
    expired_kinds = {item.get("kind") for item in expired_report.get("issues") or []}
    checks.append(drill_check(
        "expired_active_lease_detected",
        "expired_active_lease" in expired_kinds and expired_report.get("health") == "critical",
        "Doctor flags an active route whose claim lease has expired.",
        route_id="route_drill_expired",
    ))
    drill_json(base, "expire", "route_drill_expired", "--reason", "drill recovery after expired lease")
    drill_json(base, "verify", "route_drill_expired", "--verdict", "rejected", "--summary", "expired lease recovery rejected as unsuccessful")
    recovered_expired = drill_json(base, "show", "route_drill_expired")
    checks.append(drill_check(
        "expired_active_lease_recovered",
        recovered_expired.get("status") == "rejected" and recovered_expired.get("verification", {}).get("verdict") == "rejected",
        "Expired active route was moved to an audited rejected terminal state.",
        route_id="route_drill_expired",
    ))

    drill_json(
        base,
        "create",
        "--route-id",
        "route_drill_requeue",
        "--target-site",
        "lingxiaodian",
        "--target-agent",
        "codex",
        "--title-original",
        "Drill requeue guard",
    )
    drill_json(
        base,
        "claim",
        "route_drill_requeue",
        "--device-id",
        "lingxiaodian",
        "--agent-id",
        "lingxiaodian:codex",
        "--lease-seconds",
        "600",
    )
    requeue_without_force = drill_command(base, "requeue", "route_drill_requeue", "--reason", "should be rejected")
    drill_json(base, "requeue", "route_drill_requeue", "--reason", "human-reviewed drill force", "--force")
    requeued = drill_json(base, "show", "route_drill_requeue")
    checks.append(drill_check(
        "requeue_requires_review_for_live_lease",
        requeue_without_force.get("returncode") != 0 and "lease has not expired" in str(requeue_without_force.get("stderr")),
        "Requeue rejects an unexpired active lease unless explicit force is used.",
        route_id="route_drill_requeue",
    ))
    checks.append(drill_check(
        "requeue_clears_lease_and_increments_retry",
        requeued.get("status") == "queued" and requeued.get("lease") is None and requeued.get("retry_count") == 1,
        "Forced requeue clears the old lease and increments retry_count.",
        route_id="route_drill_requeue",
    ))
    drill_json(base, "cancel", "route_drill_requeue", "--reason", "drill cleanup after requeue")
    drill_json(base, "verify", "route_drill_requeue", "--verdict", "rejected", "--summary", "requeue cleanup rejected as unsuccessful")

    drill_json(
        base,
        "create",
        "--route-id",
        "route_drill_duplicate",
        "--target-site",
        "lingxiaodian",
        "--title-original",
        "Drill duplicate route record",
    )
    queued_duplicate = base / "routes" / "queued" / "route_drill_duplicate.json"
    done_duplicate = base / "routes" / "done" / "route_drill_duplicate.json"
    done_duplicate.parent.mkdir(parents=True, exist_ok=True)
    done_duplicate.write_text(queued_duplicate.read_text(encoding="utf-8"), encoding="utf-8")
    duplicate_report = drill_json(base, "doctor", "--json")
    duplicate_kinds = {item.get("kind") for item in duplicate_report.get("issues") or []}
    checks.append(drill_check(
        "duplicate_route_record_detected",
        "duplicate_route_record" in duplicate_kinds and duplicate_report.get("health") == "critical",
        "Doctor detects the same route_id stored in multiple lifecycle directories.",
        route_id="route_drill_duplicate",
    ))
    done_duplicate.unlink()
    drill_json(base, "expire", "route_drill_duplicate", "--reason", "drill cleanup after duplicate detection")
    drill_json(base, "verify", "route_drill_duplicate", "--verdict", "rejected", "--summary", "duplicate cleanup rejected as unsuccessful")

    task_path = base / "done" / "task_drill_thread.json"
    write_drill_json(task_path, {
        "task_id": "task_drill_thread",
        "route_id": "route_drill_task_link",
        "status": "success",
        "verdict": "success",
        "created_at": now(),
        "updated_at": now(),
        "summary": "Synthetic ctx-codex task result with thread mapping.",
        "codex_thread": {"id": "thread_drill_ctx_codex", "model": "gpt-test"},
    })
    drill_json(
        base,
        "create",
        "--route-id",
        "route_drill_task_link",
        "--target-site",
        "lingxiaodian",
        "--target-agent",
        "codex",
        "--title-original",
        "Drill Codex task link",
    )
    task_link_claim = drill_json(base, "claim", "route_drill_task_link", "--device-id", "lingxiaodian", "--agent-id", "lingxiaodian:codex")
    drill_json(
        base,
        "start",
        "route_drill_task_link",
        "--agent-id",
        "lingxiaodian:codex",
        "--lease-id",
        task_link_claim.get("lease_id", ""),
    )
    drill_json(
        base,
        "reply",
        "route_drill_task_link",
        "--reply-file",
        "-",
        "--agent-id",
        "lingxiaodian:codex",
        "--lease-id",
        task_link_claim.get("lease_id", ""),
        input_obj={
            "route_id": "route_drill_task_link",
            "status": "replied",
            "executed_by": "lingxiaodian:codex",
            "summary": "ctx-codex task link mapped.",
            "evidence": [{
                "kind": "ctx-codex-run",
                "task_id": "task_drill_thread",
                "result_path": str(task_path),
                "ctx_status": "success",
            }],
            "artifacts": [{"kind": "ctx-codex-result", "path": str(task_path)}],
            "secret_events": [],
            "residual_risk": "Synthetic task output only.",
            "next_action": "verify",
        },
    )
    drill_json(base, "verify", "route_drill_task_link", "--verdict", "accepted", "--summary", "task link accepted")
    task_report = drill_json(base, "doctor", "--json", "--unverified-warn-seconds", "999999")
    checks.append(drill_check(
        "ctx_codex_thread_mapping_visible",
        any(link.get("codex_thread_id") == "thread_drill_ctx_codex" for link in task_report.get("task_links") or []),
        "Doctor exposes route -> ctx-codex task -> Codex thread mapping.",
        route_id="route_drill_task_link",
        task_id="task_drill_thread",
    ))

    drill_json(
        base,
        "create",
        "--route-id",
        "route_drill_trace_parent",
        "--trace-id",
        "trace_drill_thread",
        "--target-site",
        "huaguoshan-macos",
        "--target-agent",
        "local-native",
        "--title-original",
        "Drill trace parent",
    )
    drill_json(
        base,
        "create",
        "--route-id",
        "route_drill_trace_child",
        "--target-site",
        "lingxiaodian",
        "--target-agent",
        "codex",
        "--reply-to",
        "route_drill_trace_parent",
        "--title-original",
        "Drill trace child",
    )
    trace_report = drill_json(base, "trace", "route_drill_trace_parent", "--json")
    checks.append(drill_check(
        "trace_reply_chain_visible",
        trace_report.get("trace_id") == "trace_drill_thread"
        and [item.get("route_id") for item in trace_report.get("routes") or []] == [
            "route_drill_trace_parent",
            "route_drill_trace_child",
        ]
        and not trace_report.get("warnings"),
        "Trace view merges parent/child routes by trace_id and reply_to without cross-trace warnings.",
        trace_id="trace_drill_thread",
    ))
    drill_json(base, "expire", "route_drill_trace_parent", "--reason", "drill cleanup trace parent")
    drill_json(base, "verify", "route_drill_trace_parent", "--verdict", "rejected", "--summary", "trace parent cleanup rejected as unsuccessful")
    drill_json(base, "expire", "route_drill_trace_child", "--reason", "drill cleanup trace child")
    drill_json(base, "verify", "route_drill_trace_child", "--verdict", "rejected", "--summary", "trace child cleanup rejected as unsuccessful")

    listener = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    listener.bind(("127.0.0.1", 0))
    listener.listen(1)
    ok_port = int(listener.getsockname()[1])
    down_port = reserve_closed_tcp_port()
    try:
        transport_report = drill_json(
            base,
            "doctor",
            "--json",
            "--transport-probe",
            f"drill-ok=127.0.0.1:{ok_port}",
            "--transport-probe",
            f"drill-down=127.0.0.1:{down_port}",
            "--transport-probe-timeout",
            str(transport_probe_timeout),
            "--unverified-warn-seconds",
            "999999",
        )
    finally:
        listener.close()
    transport_by_name = {item.get("name"): item for item in transport_report.get("transport_probes") or []}
    checks.append(drill_check(
        "transport_probe_reports_ok_and_down",
        transport_by_name.get("drill-ok", {}).get("ok") is True
        and transport_by_name.get("drill-down", {}).get("ok") is False
        and "transport_probe_down" in {item.get("kind") for item in transport_report.get("issues") or []},
        "Transport probes report a reachable listener and a refused listener without hiding the failure.",
    ))

    final_report = drill_json(base, "doctor", "--json", "--unverified-warn-seconds", "999999")
    unexpected_issues = [
        item for item in final_report.get("issues") or []
        if item.get("scope") == "current" and item.get("severity") in ("critical", "warn")
    ]
    checks.append(drill_check(
        "ledger_returns_to_clean_state",
        not unexpected_issues and final_report.get("health") == "ok",
        "After expected failure drills are recovered, the isolated route ledger returns to health=ok.",
        issue_count=len(unexpected_issues),
    ))

    return {
        "drill_id": f"ctx_route_drill_{stamp()}",
        "generated_at": now(),
        "base": str(base),
        "tool": str(Path(__file__).resolve()),
        "check_count": len(checks),
        "failed_check_count": len([item for item in checks if not item.get("ok")]),
        "ok": all(item.get("ok") for item in checks),
        "checks": checks,
        "expected_failure_coverage": {
            "expired_active_lease": True,
            "duplicate_route_record": True,
            "transport_probe_down": True,
            "requeue_without_review": True,
            "duplicate_active_agent_instances": True,
        },
        "final_doctor": final_report,
    }


def print_drill_text(report: dict) -> None:
    status = "ok" if report.get("ok") else "failed"
    print(f"CTX Route Drill [{status}] generated_at={report.get('generated_at')} base={report.get('base')}")
    print(f"checks={report.get('check_count')} failed={report.get('failed_check_count')}")
    for check in report.get("checks") or []:
        mark = "PASS" if check.get("ok") else "FAIL"
        print(f"- {mark} {check.get('name')}: {check.get('summary')}")
    final = report.get("final_doctor") or {}
    print(f"final_doctor_health={final.get('health')} routes={final.get('route_count')} issues={final.get('issue_count')}")


def cmd_drill(args: argparse.Namespace) -> int:
    if args.base:
        report = run_route_drill(Path(args.base), args.transport_probe_timeout)
    else:
        with tempfile.TemporaryDirectory(prefix="ctx-route-drill-") as tmp:
            report = run_route_drill(Path(tmp), args.transport_probe_timeout)
    if args.json:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    else:
        print_drill_text(report)
    if args.strict and not report.get("ok"):
        return 2
    return 0


def stable_slug(value: str) -> str:
    return re.sub(r"[^A-Za-z0-9_:-]+", "_", value).strip("_")[:80] or "batch"


def cmd_stability_create(args: argparse.Namespace) -> int:
    batch_id = stable_slug(args.batch_id or f"ctx_l2_stability_{stamp()}")
    trace_id = stable_slug(args.trace_id or f"trace_{batch_id}")
    lane_id = stable_slug(args.lane_id or args.work_chat_id or args.context_id or trace_id)
    capabilities = parse_csv_arg(args.capability)
    constraints = parse_csv_arg(args.constraint) or ["read_only_first", "no_secrets"]
    artifacts_expected = parse_csv_arg(args.artifact_expected) or ["summary", "evidence"]
    secret_capabilities = parse_csv_arg(args.secret_capability)
    created: list[dict] = []
    with locked():
        for index in range(1, args.count + 1):
            route_id = stable_slug(args.route_id_template.format(
                batch_id=batch_id,
                index=index,
                stamp=stamp(),
            ))
            title = args.title_template.format(batch_id=batch_id, index=index, count=args.count)
            instructions = args.instructions_template.format(batch_id=batch_id, index=index, count=args.count)
            path, route = create_route_record(
                route_id=route_id,
                trace_id=trace_id,
                status=args.status,
                created_by=args.created_by,
                origin_site=args.origin_site,
                origin_agent=args.origin_agent,
                target_site=args.target_site,
                target_agent=args.target_agent,
                task_kind=args.task_kind,
                title_original=title,
                title_auto=args.title_auto_template.format(batch_id=batch_id, index=index, count=args.count)
                if args.title_auto_template
                else title,
                capabilities=capabilities,
                constraints=constraints,
                approval_required=args.approval_required,
                secret_capabilities=secret_capabilities,
                reply_to=None,
                artifacts_expected=artifacts_expected,
                probe=args.probe,
                cwd=args.cwd,
                instructions=instructions,
                lane_id=lane_id,
                work_chat_id=args.work_chat_id,
                context_id=args.context_id,
            )
            created.append({
                "route_id": route["route_id"],
                "trace_id": route["trace_id"],
                "lane_id": route["lane_id"],
                "work_chat_id": route.get("work_chat_id"),
                "context_id": route.get("context_id"),
                "path": str(path),
                "status": route["status"],
                "target": f"{route['target_site']}:{route['target_agent']}",
                "title": route["title_auto"],
            })
    output = {
        "batch_id": batch_id,
        "trace_id": trace_id,
        "lane_id": lane_id,
        "work_chat_id": args.work_chat_id,
        "context_id": args.context_id,
        "created_at": now(),
        "count": len(created),
        "routes": created,
        "next_commands": [
            f"ctx-route stability-report --trace-id {trace_id} --wait-seconds 0 --json",
        ],
    }
    if args.json:
        print(json.dumps(output, ensure_ascii=False, indent=2))
    else:
        print(f"CTX Stability Batch Created batch_id={batch_id} trace_id={trace_id} lane_id={lane_id} routes={len(created)}")
        for route in created:
            print(f"- {route['route_id']} [{route['status']}] {route['target']} {route['title']}")
    return 0


def route_is_terminal(route: dict) -> bool:
    return route.get("status") in TERMINAL_STATUSES


def selected_routes(route_ids: list[str], trace_id: str | None = None) -> list[tuple[Path, dict]]:
    selected: dict[str, tuple[Path, dict]] = {}
    for rid in route_ids:
        path, route = load_route(rid)
        selected[str(route.get("route_id") or rid)] = (path, route)
    if trace_id:
        for path, route in iter_routes():
            if route.get("trace_id") == trace_id:
                selected[str(route.get("route_id") or path.stem)] = (path, route)
    return sorted(selected.values(), key=lambda item: (item[1].get("created_at") or "", item[1].get("route_id") or ""))


def verify_route_record(route_id: str, verified_by: str, verdict: str, summary: str) -> dict:
    with locked():
        path, route = load_route(route_id)
        if route.get("verification"):
            return {"route_id": route_id, "status": route.get("status"), "path": str(path), "already_verified": True}
        if route.get("status") not in UNVERIFIED_TERMINAL_STATUSES:
            return {"route_id": route_id, "status": route.get("status"), "path": str(path), "skipped": True}
        new_path = apply_verification(path, route, verified_by, verdict, summary)
        status = route.get("status")
    return {"route_id": route_id, "status": status, "path": str(new_path), "verdict": verdict}


def agent_instance_by_id(instances: list[dict]) -> dict[str, dict]:
    return {str(item.get("instance_id")): item for item in instances if item.get("instance_id")}


def summarize_stability_route(
    route: dict,
    instances_by_id: dict[str, dict],
    metric_events_by_instance: dict[str, list[dict]] | None = None,
) -> dict:
    lease = route.get("lease") if isinstance(route.get("lease"), dict) else {}
    reply = route.get("reply") if isinstance(route.get("reply"), dict) else {}
    verification = route.get("verification") if isinstance(route.get("verification"), dict) else {}
    claim_instance_id = lease.get("claim_instance_id")
    instance = instances_by_id.get(str(claim_instance_id)) if claim_instance_id else None
    metrics = instance.get("metrics") if isinstance(instance, dict) and isinstance(instance.get("metrics"), dict) else {}
    agent_code = instance.get("agent_code") if isinstance(instance, dict) and isinstance(instance.get("agent_code"), dict) else {}
    created_at = parse_time(route.get("created_at"))
    updated_at = parse_time(route.get("updated_at"))
    elapsed_seconds = int((updated_at - created_at).total_seconds()) if created_at and updated_at else None
    latency_view = (
        metrics_latency_view(
            metrics,
            created_at,
            updated_at,
            fallback_to_lifetime=False,
            ledger_events=(metric_events_by_instance or {}).get(str(claim_instance_id)),
        )
        if metrics or (claim_instance_id and (metric_events_by_instance or {}).get(str(claim_instance_id)))
        else {}
    )
    return {
        "route_id": route.get("route_id"),
        "trace_id": route.get("trace_id") or route.get("route_id"),
        "lane_id": route_lane_id(route),
        "work_chat_id": route.get("work_chat_id"),
        "context_id": route.get("context_id"),
        "status": route.get("status"),
        "target": f"{route.get('target_site')}:{route.get('target_agent')}",
        "title": route.get("title_auto") or route.get("title_original"),
        "created_at": route.get("created_at"),
        "updated_at": route.get("updated_at"),
        "elapsed_seconds": elapsed_seconds,
        "event_types": [event.get("type") for event in route.get("events") or [] if isinstance(event, dict)],
        "claimed_by": lease.get("claimed_by"),
        "claim_instance_id": claim_instance_id,
        "claim_instance_state": instance.get("state") if isinstance(instance, dict) else None,
        "claim_instance_last_seen": instance.get("last_seen") if isinstance(instance, dict) else None,
        "agent_code_sha256": agent_code.get("sha256") if agent_code else None,
        "agent_code_mtime": agent_code.get("mtime") if agent_code else None,
        "route_call_count": metrics.get("call_count") if metrics else None,
        "route_call_failed_count": metrics.get("failed_call_count") if metrics else None,
        "route_call_max_elapsed_ms": latency_view.get("max_elapsed_ms") if latency_view else None,
        "route_call_max_operation": (latency_view.get("max_event") or {}).get("operation") if latency_view else None,
        "route_call_max_attempts": (latency_view.get("max_event") or {}).get("attempts") if latency_view else None,
        "route_call_max_observed_at": (latency_view.get("max_event") or {}).get("observed_at") if latency_view else None,
        "route_call_metric_event_id": (latency_view.get("max_event") or {}).get("event_id") if latency_view else None,
        "route_call_metric_path": (latency_view.get("max_event") or {}).get("path") if latency_view else None,
        "route_call_latency_scope": latency_view.get("scope") if latency_view else None,
        "route_call_latency_sample_count": latency_view.get("sample_count") if latency_view else None,
        "route_call_latency_observed_after": latency_view.get("observed_after") if latency_view else None,
        "route_call_latency_observed_before": latency_view.get("observed_before") if latency_view else None,
        "reply_status": reply.get("status"),
        "executed_by": reply.get("executed_by"),
        "reply_summary": safe_text(reply.get("summary"), 500),
        "verification_verdict": verification.get("verdict"),
        "verified_by": verification.get("verified_by"),
    }


def stability_checks(
    routes: list[dict],
    route_summaries: list[dict],
    doctor: dict,
    args: argparse.Namespace,
) -> list[dict]:
    total = len(routes)
    statuses = Counter(str(route.get("status")) for route in routes)
    terminal_count = sum(1 for route in routes if route_is_terminal(route))
    successful_verified = sum(
        1
        for item in route_summaries
        if (
            item.get("reply_status") == "replied"
            and item.get("status") == "verified"
            and item.get("verification_verdict") == "accepted"
        )
    )
    failed_reply_statuses = [
        {
            "route_id": item.get("route_id"),
            "status": item.get("status"),
            "reply_status": item.get("reply_status"),
        }
        for item in route_summaries
        if item.get("status") in TERMINAL_STATUSES
        and item.get("reply_status") not in (None, "replied")
    ]
    missing_claim = [item for item in route_summaries if not item.get("claim_instance_id")]
    missing_code = [item for item in route_summaries if item.get("claim_instance_id") and not item.get("agent_code_sha256")]
    high_latency = [
        item for item in route_summaries
        if args.agent_latency_warn_ms > 0
        and isinstance(item.get("route_call_max_elapsed_ms"), int)
        and item["route_call_max_elapsed_ms"] > args.agent_latency_warn_ms
    ]
    missing_latency = [
        item for item in route_summaries
        if args.agent_latency_warn_ms > 0
        and item.get("claim_instance_id")
        and not isinstance(item.get("route_call_max_elapsed_ms"), int)
    ]
    current_warns = [
        item for item in doctor.get("issues") or []
        if item.get("scope") == "current" and item.get("severity") in ("warn", "critical")
    ]
    circuit_breaker = doctor.get("circuit_breaker") or {}
    return [
        drill_check(
            "all_routes_reached_terminal_state",
            total > 0 and terminal_count == total,
            "Every route in the selected live batch reached a terminal state.",
            total=total,
            terminal=terminal_count,
            status_counts=dict(sorted(statuses.items())),
        ),
        drill_check(
            "all_routes_replied_or_verified",
            total > 0 and successful_verified == total,
            "Every selected route produced a successful reply and passed accepted verification.",
            total=total,
            replied_or_verified=successful_verified,
            status_counts=dict(sorted(statuses.items())),
            failed_reply_statuses=failed_reply_statuses,
        ),
        drill_check(
            "claim_instance_ids_present",
            not missing_claim,
            "Every selected route has an explicit claimant instance id in its lease.",
            missing=[item.get("route_id") for item in missing_claim],
        ),
        drill_check(
            "claimant_code_fingerprints_present",
            not missing_code,
            "Every selected route with a claimant instance links to an agent heartbeat with a code sha256.",
            missing=[item.get("route_id") for item in missing_code],
        ),
        drill_check(
            "route_call_latency_within_threshold",
            not high_latency and not missing_latency,
            "Claimant route-ledger call latency stayed within the configured threshold.",
            threshold_ms=args.agent_latency_warn_ms,
            offenders=[
                {
                    "route_id": item.get("route_id"),
                    "instance_id": item.get("claim_instance_id"),
                    "max_elapsed_ms": item.get("route_call_max_elapsed_ms"),
                    "operation": item.get("route_call_max_operation"),
                    "attempts": item.get("route_call_max_attempts"),
                    "observed_at": item.get("route_call_max_observed_at"),
                    "metric_event_id": item.get("route_call_metric_event_id"),
                    "metric_path": item.get("route_call_metric_path"),
                }
                for item in high_latency
            ],
            missing_evidence=[
                {
                    "route_id": item.get("route_id"),
                    "instance_id": item.get("claim_instance_id"),
                    "latency_scope": item.get("route_call_latency_scope"),
                    "observed_after": item.get("route_call_latency_observed_after"),
                    "observed_before": item.get("route_call_latency_observed_before"),
                }
                for item in missing_latency
            ],
        ),
        drill_check(
            "circuit_breaker_closed",
            circuit_breaker.get("state") != "open",
            "Circuit breaker is closed before declaring the selected batch stable.",
            state=circuit_breaker.get("state"),
            severity=circuit_breaker.get("severity"),
            reason=circuit_breaker.get("reason"),
            opened_at=circuit_breaker.get("opened_at"),
        ),
        drill_check(
            "doctor_has_no_current_warn_or_critical",
            not current_warns,
            "Doctor has no current warn/critical issues under the selected stability thresholds.",
            health=doctor.get("health"),
            current_issue_counts=doctor.get("current_issue_counts"),
        ),
    ]


def cmd_stability_report(args: argparse.Namespace) -> int:
    if not args.trace_id and not args.route_id:
        raise SystemExit("stability-report requires --trace-id or --route-id")
    deadline = time.monotonic() + max(0, args.wait_seconds)
    routes_with_paths = selected_routes(args.route_id or [], args.trace_id)
    while args.wait_seconds > 0 and routes_with_paths and not all(route_is_terminal(route) for _path, route in routes_with_paths):
        if time.monotonic() >= deadline:
            break
        time.sleep(max(1, args.poll_interval))
        routes_with_paths = selected_routes(args.route_id or [], args.trace_id)

    verification_results = []
    if args.auto_verify:
        for _path, route in routes_with_paths:
            if route.get("verification") or not route_is_terminal(route):
                continue
            route_id = str(route.get("route_id"))
            reply = route.get("reply") if isinstance(route.get("reply"), dict) else {}
            verdict = (
                "accepted"
                if route.get("status") == "replied" and reply.get("status") == "replied"
                else args.non_replied_verdict
            )
            summary = (
                f"stability-report auto verification for {route.get('status')} "
                f"route in trace {args.trace_id or route.get('trace_id')}"
            )
            verification_results.append(verify_route_record(route_id, args.verified_by, verdict, summary))
        routes_with_paths = selected_routes(args.route_id or [], args.trace_id)

    route_records = [route for _path, route in routes_with_paths]
    instances_by_id = agent_instance_by_id(load_agent_instances())
    metric_events_by_instance = route_call_metric_events_by_instance(load_route_call_metric_events())
    route_summaries = [
        summarize_stability_route(route, instances_by_id, metric_events_by_instance)
        for route in route_records
    ]
    doctor_args = argparse.Namespace(**vars(args))
    if (
        args.agent_latency_warn_ms > 0
        and not getattr(args, "agent_latency_observed_after", "")
        and route_records
    ):
        created_times = [
            parse_time(route.get("created_at"))
            for route in route_records
            if parse_time(route.get("created_at"))
        ]
        if created_times:
            doctor_args.agent_latency_observed_after = min(created_times).isoformat().replace("+00:00", "Z")
    doctor = doctor_report(doctor_args)
    checks = stability_checks(route_records, route_summaries, doctor, args)
    ok = bool(route_records) and all(check.get("ok") for check in checks)
    report = {
        "report_id": f"ctx_l2_stability_report_{stamp()}",
        "generated_at": now(),
        "trace_id": args.trace_id,
        "route_ids": [route.get("route_id") for route in route_records],
        "route_count": len(route_records),
        "ok": ok,
        "check_count": len(checks),
        "failed_check_count": len([item for item in checks if not item.get("ok")]),
        "checks": checks,
        "verification_results": verification_results,
        "routes": route_summaries,
        "doctor": doctor,
    }
    if args.json:
        print(json.dumps(report, ensure_ascii=False, indent=2))
    else:
        status = "ok" if ok else "not-ok"
        print(f"CTX L2 Stability Report [{status}] generated_at={report['generated_at']} trace_id={args.trace_id}")
        print(f"routes={report['route_count']} checks={report['check_count']} failed={report['failed_check_count']}")
        for check in checks:
            mark = "PASS" if check.get("ok") else "FAIL"
            print(f"- {mark} {check.get('name')}: {check.get('summary')}")
        for route in route_summaries:
            print(
                f"- {route.get('route_id')} [{route.get('status')}] "
                f"claim_instance={route.get('claim_instance_id') or 'missing'} "
                f"code_sha={route.get('agent_code_sha256') or 'missing'} "
                f"max_call_ms={route.get('route_call_max_elapsed_ms')}"
            )
        print(f"doctor_health={doctor.get('health')} current_issues={doctor.get('current_issue_counts')}")
    if args.strict and not ok:
        return 2
    return 0


