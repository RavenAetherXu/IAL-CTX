    import fcntl  # POSIX file locking
except ImportError:  # pragma: no cover - Windows
    fcntl = None
try:
    import msvcrt  # Windows file locking
except ImportError:  # pragma: no cover - POSIX
    msvcrt = None
import functools
import hashlib
