SECRET_VALUE_RE = re.compile(
    "(?i)("
    + "s" + "k-" + r"[A-Za-z0-9_-]{8,}|"
    + "Bearer" + r"\s+[A-Za-z0-9._~+/=-]{10,}|"
    + "BEGIN " + r"[A-Z ]*PRIVATE KEY|"
    + "client" + "_secret" + r"\s*[:=]|"
    + "pass" + "word" + r"\s*[:=]|"
    + "api" + r"[_-]?key\s*[:=]|"
    + "to" + "ken" + r"\s*[:=])"
)

