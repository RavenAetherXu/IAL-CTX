#!/usr/bin/env python3
"""Windows-portable CTX claimant for local and spoke-style route ledgers."""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import shlex
import subprocess
import sys
from pathlib import Path


DEVICE_ID = os.environ.get("CTX_DEVICE_ID", "windows-local")
AGENT_KEY = os.environ.get("CTX_AGENT_KEY", f"{DEVICE_ID}/codex-local")
AGENT_ID = os.environ.get("CTX_AGENT_ID", f"{DEVICE_ID}:codex-local")
INSTANCE_ID = os.environ.get("CTX_AGENT_INSTANCE_ID", f"{DEVICE_ID}:{os.getpid()}")
REMOTE = os.environ.get("CTX_REMOTE", "")
ROUTE_CMD = os.environ.get("CTX_ROUTE", "ctx-route")
CODEX_CMD = os.environ.get("CTX_CODEX", "ctx-codex-bridge")
CAPABILITIES = ["os.windows", "runtime.codex", "runtime.shell", "probe.read-only", "ctx.route"]
ALLOWED_CONSTRAINTS = {"read_only_first", "no_secrets"}


def now() -> str:
    return dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def split_cmd(value: str) -> list[str]:
    return shlex.split(value, posix=(os.name != "nt"))


def local_route_cmd() -> list[str]:
    parts = split_cmd(ROUTE_CMD)
    if len(parts) == 1 and parts[0] == "ctx-route":
        return [sys.executable, str(Path(__file__).resolve().with_name("ctx-route"))]
    return parts


def local_codex_cmd() -> list[str]:
    parts = split_cmd(CODEX_CMD)
    if len(parts) == 1 and parts[0] == "ctx-codex-bridge":
        return [sys.executable, str(Path(__file__).resolve().with_name("ctx-codex-bridge"))]
    return parts


def profile_transports() -> list[str]:
    explicit = os.environ.get("CTX_TRANSPORT", "").strip()
    if explicit:
        return [item.strip() for item in explicit.split(",") if item.strip()]
    return ["transport.local"] if not REMOTE else ["frp-reverse-ssh:example.invalid"]


def route_json(args: list[str], input_obj: dict | None = None) -> object:
    data = json.dumps(input_obj, ensure_ascii=False) if input_obj is not None else None
    if REMOTE:
        remote_command = " ".join(shlex.quote(part) for part in [*split_cmd(ROUTE_CMD), *args])
        cmd = ["ssh", REMOTE, remote_command]
    else:
        cmd = [*local_route_cmd(), *args]
    result = subprocess.run(cmd, input=data, text=True, capture_output=True, timeout=60)
    if result.returncode != 0:
        raise RuntimeError((result.stderr or result.stdout or "ctx-route command failed").strip())
    out = (result.stdout or "").strip()
    return json.loads(out) if out else None


def device_profile() -> dict:
    return {
        "device_id": DEVICE_ID,
        "site": DEVICE_ID,
        "os": "windows",
        "availability": "intermittent",
        "agents": ["local-codex-executor"],
        "capabilities": CAPABILITIES,
        "transports": profile_transports(),
        "last_seen": now(),
        "health": "up",
        "red_lines": ["metadata_first", "no_secret_values", "no_admin_without_approval"],
    }


def agent_profile() -> dict:
    return {
        "schema": "ctx-agent-profile-v1",
        "agent_key": AGENT_KEY,
        "agent_id": AGENT_ID,
        "device_id": DEVICE_ID,
        "engine": {"name": "codex-bridge", "version": "0.1.0", "model": "local"},
        "kind": "executor",
        "capabilities": CAPABILITIES,
        "constraints_supported": sorted(ALLOWED_CONSTRAINTS),
        "transports": profile_transports(),
        "availability": "intermittent",
        "audit_profile": {
            "result_link_kind": "ctx-codex-result",
            "expects_thread_id": False,
            "ephemeral_session": True,
        },
        "secret_capabilities": [],
        "registered_at": now(),
        "red_lines": ["metadata_first", "no_secret_values", "no_admin_without_approval"],
    }


def register() -> dict:
    route_json(["device-upsert", "--profile-file", "-"], device_profile())
    return route_json(["agent-register", "--profile-file", "-"], agent_profile())


def route_eligible(route: dict) -> bool:
    if route.get("target_site") != DEVICE_ID:
        return False
    if route.get("status") != "queued":
        return False
    if not set(route.get("required_capabilities") or []).issubset(set(CAPABILITIES)):
        return False
    if not set(route.get("constraints") or []).issubset(ALLOWED_CONSTRAINTS):
        return False
    if route.get("approval_required"):
        return False
    if route.get("secret_capabilities") or []:
        return False
    return True


def queued_routes() -> list[dict]:
    rows = route_json(["list", "--status", "queued", "--target-site", DEVICE_ID, "--json"])
    return rows if isinstance(rows, list) else []


def claim_one() -> dict | None:
    register()
    for route in queued_routes():
        if not route_eligible(route):
            continue
        try:
            claim = route_json([
                "claim",
                route["route_id"],
                "--device-id",
                DEVICE_ID,
                "--agent-id",
                AGENT_ID,
                "--instance-id",
                INSTANCE_ID,
                "--lease-seconds",
                "600",
            ])
            if isinstance(claim, dict):
                claim["route"] = route
            return claim
        except RuntimeError as exc:
            if "route not claimable:" in str(exc) or "status=" in str(exc):
                continue
            raise
    return None


def task_text(route: dict) -> str:
    parts = [
        str(route.get("title_original") or route.get("title_auto") or route.get("route_id")),
        str(route.get("instructions") or ""),
        "",
        "End with:",
        "CTX-VERDICT: success | blocked | failed",
        "CTX-ARTIFACTS: <comma-separated paths, or none>",
        "CTX-RESIDUAL: <one line residual risk, or none>",
    ]
    return "\n".join(part for part in parts if part is not None)


def execute_claim(claim: dict) -> dict:
    route = claim.get("route") if isinstance(claim.get("route"), dict) else route_json(["show", claim["route_id"]])
    rid = str(route["route_id"])
    lease_id = str(claim.get("lease_id") or "")
    start_args = ["start", rid, "--agent-id", AGENT_ID, "--instance-id", INSTANCE_ID]
    if lease_id:
        start_args.extend(["--lease-id", lease_id])
    route_json(start_args)
    env = {**os.environ, "CTX_TASK_ID": rid}
    cmd = [*local_codex_cmd(), "run", "--task", task_text(route), "--task-id", rid]
    if route.get("cwd"):
        cmd.extend(["--cwd", str(route["cwd"])])
    result = subprocess.run(cmd, text=True, capture_output=True, timeout=900, env=env)
    codex_result_path = None
    codex_status = "failed"
    if result.stdout.strip():
        try:
            payload = json.loads(result.stdout.strip().splitlines()[-1])
            codex_result_path = payload.get("result_path")
            codex_status = payload.get("status") or codex_status
        except json.JSONDecodeError:
            pass
    status = "replied" if result.returncode == 0 and codex_status == "replied" else "failed"
    reply = {
        "route_id": rid,
        "status": status,
        "replied_at": now(),
        "executed_by": AGENT_ID,
        "summary": "ctx-win-agent executed route through ctx-codex-bridge" if status == "replied" else "ctx-win-agent ctx-codex-bridge execution failed",
        "evidence": [{
            "kind": "ctx-codex-result",
            "path": codex_result_path or "",
            "exit_code": result.returncode,
        }],
        "artifacts": ([{"kind": "ctx-codex-result", "path": codex_result_path}] if codex_result_path else []),
        "secret_events": [],
        "residual_risk": "Result is metadata-first; Windows-specific behavior was not exercised on this POSIX host.",
        "next_action": "verify" if status == "replied" else "reroute",
    }
    reply_args = ["reply", rid, "--reply-file", "-", "--agent-id", AGENT_ID, "--instance-id", INSTANCE_ID]
    if lease_id:
        reply_args.extend(["--lease-id", lease_id])
    route_json(reply_args, reply)
    return reply


def cmd_register(_args: argparse.Namespace) -> int:
    print(json.dumps(register(), ensure_ascii=False))
    return 0


def cmd_claim(_args: argparse.Namespace) -> int:
    claim = claim_one()
    print(json.dumps(claim or {"claimed": None}, ensure_ascii=False))
    return 0


def cmd_execute(args: argparse.Namespace) -> int:
    route = route_json(["show", args.route_id])
    if not isinstance(route, dict):
        raise RuntimeError("route not found")
    if route.get("status") == "queued":
        claim = route_json([
            "claim",
            args.route_id,
            "--device-id",
            DEVICE_ID,
            "--agent-id",
            AGENT_ID,
            "--instance-id",
            INSTANCE_ID,
            "--lease-seconds",
            "600",
        ])
        if isinstance(claim, dict):
            claim["route"] = route
    else:
        claim = {"route_id": args.route_id, "route": route, "lease_id": (route.get("lease") or {}).get("lease_id")}
    print(json.dumps(execute_claim(claim), ensure_ascii=False))
    return 0


def add_optional_create_arg(parts: list[str], flag: str, value: str | None) -> None:
    if value:
        parts.extend([flag, value])


def cmd_publish(args: argparse.Namespace) -> int:
    create_args = [
        "create",
        "--created-by",
        args.created_by or AGENT_ID,
        "--origin-site",
        args.origin_site or DEVICE_ID,
        "--origin-agent",
        args.origin_agent or AGENT_ID,
        "--target-site",
        args.target_site,
        "--title-original",
        args.title_original,
    ]
    add_optional_create_arg(create_args, "--route-id", args.route_id)
    add_optional_create_arg(create_args, "--trace-id", args.trace_id)
    add_optional_create_arg(create_args, "--lane-id", args.lane_id)
    add_optional_create_arg(create_args, "--work-chat-id", args.work_chat_id)
    add_optional_create_arg(create_args, "--context-id", args.context_id)
    add_optional_create_arg(create_args, "--target-agent", args.target_agent)
    add_optional_create_arg(create_args, "--task-kind", args.task_kind)
    add_optional_create_arg(create_args, "--title-auto", args.title_auto)
    add_optional_create_arg(create_args, "--reply-to", args.reply_to)
    add_optional_create_arg(create_args, "--artifact-expected", args.artifact_expected)
    add_optional_create_arg(create_args, "--probe", args.probe)
    add_optional_create_arg(create_args, "--cwd", args.cwd)
    add_optional_create_arg(create_args, "--instructions", args.instructions)
    for capability in args.capability or []:
        create_args.extend(["--capability", capability])
    for constraint in args.constraint or []:
        create_args.extend(["--constraint", constraint])
    if args.approval_required:
        create_args.append("--approval-required")
    for secret_capability in args.secret_capability or []:
        create_args.extend(["--secret-capability", secret_capability])
    print(json.dumps(route_json(create_args), ensure_ascii=False))
    return 0


def cmd_reply(_args: argparse.Namespace) -> int:
    raise SystemExit("reply is performed by execute/once after ctx-codex returns")


def cmd_once(_args: argparse.Namespace) -> int:
    claim = claim_one()
    if not claim:
        print(json.dumps({"processed": 0}, ensure_ascii=False))
        return 0
    reply = execute_claim(claim)
    print(json.dumps({"processed": 1, "route_id": reply["route_id"], "status": reply["status"]}, ensure_ascii=False))
    return 0 if reply["status"] == "replied" else 1


def main() -> int:
    parser = argparse.ArgumentParser(prog="ctx-win-agent")
    sub = parser.add_subparsers(dest="cmd", required=True)
    sub.add_parser("register").set_defaults(func=cmd_register)
    sub.add_parser("claim").set_defaults(func=cmd_claim)
    execute = sub.add_parser("execute")
    execute.add_argument("route_id")
    execute.set_defaults(func=cmd_execute)
    publish = sub.add_parser("publish")
    publish.add_argument("--route-id")
    publish.add_argument("--trace-id")
    publish.add_argument("--lane-id")
    publish.add_argument("--work-chat-id")
    publish.add_argument("--context-id")
    publish.add_argument("--created-by")
    publish.add_argument("--origin-site")
    publish.add_argument("--origin-agent")
    publish.add_argument("--target-site", required=True)
    publish.add_argument("--target-agent")
    publish.add_argument("--task-kind", default="inspect")
    publish.add_argument("--title-original", required=True)
    publish.add_argument("--title-auto")
    publish.add_argument("--capability", action="append")
    publish.add_argument("--constraint", action="append")
    publish.add_argument("--approval-required", action="store_true")
    publish.add_argument("--secret-capability", action="append")
    publish.add_argument("--reply-to")
    publish.add_argument("--artifact-expected")
    publish.add_argument("--probe")
    publish.add_argument("--cwd")
    publish.add_argument("--instructions")
    publish.set_defaults(func=cmd_publish)
    sub.add_parser("reply").set_defaults(func=cmd_reply)
    sub.add_parser("once").set_defaults(func=cmd_once)
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
